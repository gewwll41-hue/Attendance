<!DOCTYPE html>
<html>

<head>
    <meta http-equiv="X-UA-Compatible" content="IE=9" />
    <meta http-equiv="Content-Type" content="text/html; charset=windows-1252" />
    <meta http-equiv="Cache-Control" content="no-cache" />
    <title>Setting Glass Mode (GM) - TDA</title>
    <HTA:APPLICATION ID="objHTA" APPLICATIONNAME="Setting Glass Mode (GM) - TDA" WINDOWSTATE="normal" SINGLEINSTANCE="yes"
        BORDER="none" SELECTION="no">
    </HTA:APPLICATION>
    <style>
        * {
            color: white;
            margin: 0;
            padding: 0;
            overflow: hidden;
            box-sizing: border-box;
            outline: none;
            border: none;
            text-align: center;
            justify-content: center;
            align-items: center;
            max-width: 1024px;
            max-height: 768px;
            font-family: 'Consolas', 'Lucida Console', 'Courier New', monospace;
        }
        
        body {
            display: flex;
            margin: 0 auto;
            background: #001e32;
            background-image: url("data:image/png;base64,") !important;
            background-position: center calc(50% + 8px);
            background-size: 200%;
        }
        
        h3 {
            padding: 5px;
            margin-bottom: 10px;
            border-radius: 25px 7px;
            background: rgba(0, 30, 50, 0.5);
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: -0.3px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            box-shadow: inset 0 14px 18px -10px rgba(0, 213, 255, 0.45), inset 0 -14px 18px -10px rgba(0, 213, 255, 0.45), inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
        
        input[type="text"] {
            flex: 1;
            background: rgba(0, 30, 50, 0.5);
            border: 3px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            border-radius: 25px 7px;
            padding: 7px 18px;
            padding-bottom: 9px;
            font-size: 0.7rem;
            display: block;
            margin: 8px auto;
            cursor: text;
            width: 380px;
            min-height: 35px;
            box-shadow: inset 0 10px 14px -10px rgba(0, 213, 255, 0.35), inset 0 -10px 14px -10px rgba(0, 213, 255, 0.35), inset 7px 0 14px rgba(0, 213, 255, 0.28), inset -7px 0 14px rgba(0, 213, 255, 0.28);
        }
        
        input[type="text"]:hover {
            background: rgba(0, 221, 255, 0.30);
        }
        
        button {
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            background: rgba(0, 30, 50, 0.5) !important;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            padding: 10px 20px;
            border-radius: 25px 7px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            letter-spacing: 0.5px;
            box-shadow: inset 0 10px 14px -10px rgba(0, 213, 255, 0.35), inset 0 -10px 14px -10px rgba(0, 213, 255, 0.35), inset 7px 0 14px rgba(0, 213, 255, 0.28), inset -7px 0 14px rgba(0, 213, 255, 0.28);
        }
        
        button:hover {
            background: rgba(0, 213, 255, 0.30) !important;
            border-color: #00d5ff !important;
        }
        
        a {
            display: inline-block;
            text-align: center;
            padding: 6px 16px;
            border-radius: 24px 7px;
            text-decoration: none;
        }
        
        .container {
            background: rgba(0, 0, 0, 0.5);
            margin: 10px auto;
            border-radius: 25px 7px;
            padding: 10px 10px 8px 10px;
            width: 98%;
            box-shadow: 0 20px 35px rgba(0, 213, 255, 0.4), 0 -20px 35px rgba(0, 213, 255, 0.4), 20px 0 35px rgba(0, 213, 255, 0.4), -20px 0 35px rgba(0, 213, 255, 0.4), 15px 15px 40px rgba(0, 213, 255, 0.19), -15px -15px 40px rgba(0, 213, 255, 0.19), 0 0 0 1px rgb(0, 213, 255);
        }
        
        #mainPanel,
        #spesificListPanel,
        #informationPanel {
            display: block;
            width: 100%;
            margin: 10px 0;
            padding: 5px;
            border-radius: 25px 7px;
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            box-shadow: inset 0 14px 18px -10px rgba(0, 213, 255, 0.45), inset 0 -14px 18px -10px rgba(0, 213, 255, 0.45), inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
        
        .header {
            display: inline-block;
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            font-size: 1rem;
            border-radius: 25px 7px;
            margin: 5px auto;
            padding: 4px 15px;
            background: rgba(0, 30, 50, 0.5);
            font-weight: 700;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            box-shadow: inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
        
        .list-content {
            display: block;
            flex-wrap: wrap;
            background: rgba(0, 30, 50, 0.5);
            border-radius: 25px 7px;
            margin: 10px auto;
            padding: 10px 2px 6px 2px;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            box-shadow: inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }

        .list-content label {
            display: inline-block;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            background: rgba(0, 30, 50, 0.5);
            padding: 6px 12px;
            margin: 2px 4px;
            border-radius: 25px 7px;
            white-space: nowrap;
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
        }
        
        .list-content label:hover {
            background: rgba(0, 213, 255, 0.30);
        }
        
        .list-content input {
            width: 0;
            height: 0;
        }
        
        .list-content input:checked+label {
            background: rgba(0, 221, 255, 0.30);
        }
        
        .btn-danger {
            background: rgba(142, 46, 46, 0.5) !important;
            border-color: #ff4d4d !important;
            box-shadow: inset 0 10px 14px -10px rgba(255, 77, 77, 0.35), inset 0 -10px 14px -10px rgba(255, 77, 77, 0.35), inset 7px 0 14px rgba(255, 77, 77, 0.28), inset -7px 0 14px rgba(255, 77, 77, 0.28);
        }
        
        .btn-danger:hover {
            background: rgba(255, 77, 77, 0.5) !important;
            border-color: #ff4d4d !important;
        }
        
        .btn-list {
            width: 30px;
            height: 20px;
            margin: 0;
            padding: 0;
            cursor: pointer;
        }

        .btn-up-number {
            position: absolute !important;
            left: 5px !important;
            top: 47px !important;
            padding: 0 !important;
        }

        .btn-down-number {
            position: absolute !important;
            right: 5px !important;
            top: 47px !important;
            padding: 0 !important;
        }

        .info-text {
            font-size: 0.75rem;
            line-height: 1.4;
            margin-bottom: 6px;
            display: block;
            padding-left: 8px;
        }

        .info-text-highlight {
            font-size: 0.8rem;
            color: #ffbb33;
        }

        .info-text-list,
        .info-text-left,
        .info-text-right {
            font-size: 0.8rem;
            padding-left: 8px;
            text-align: left;
        }

        .info-list {
            margin: 6px 0 6px 20px;
            list-style-type: square;
        }

        .whatsapp {
            border-color: #25D366;
            background-color: rgba(37, 211, 102, 0.2);
            box-shadow: inset 10px 0 20px rgba(37, 211, 102, 0.35), inset -10px 0 20px rgba(37, 211, 102, 0.35);
        }

        .whatsapp:hover {
            background-color: rgba(37, 211, 102, 0.7);
            box-shadow: inset 0 10px 18px -10px rgba(37, 211, 102, 0.55), inset 0 -10px 18px -10px rgba(37, 211, 102, 0.55), inset 12px 0 22px rgba(37, 211, 102, 0.45), inset -12px 0 22px rgba(37, 211, 102, 0.45), 0 0 10px rgba(37, 211, 102, 0.35);
        }

        .facebook {
            border-color: #1877F2;
            background-color: rgba(24, 119, 242, 0.2);
            box-shadow: inset 10px 0 20px rgba(24, 119, 242, 0.35), inset -10px 0 20px rgba(24, 119, 242, 0.35);
        }

        .facebook:hover {
            background-color: rgba(24, 119, 242, 0.7);
            box-shadow: inset 0 10px 18px -10px rgba(24, 119, 242, 0.55), inset 0 -10px 18px -10px rgba(24, 119, 242, 0.55), inset 12px 0 22px rgba(24, 119, 242, 0.45), inset -12px 0 22px rgba(24, 119, 242, 0.45), 0 0 10px rgba(24, 119, 242, 0.35);
        }

        .instagram {
            border-color: #DD2A7B;
            background-color: rgba(221, 42, 123, 0.2);
            box-shadow: inset 10px 0 20px rgba(221, 42, 123, 0.35), inset -10px 0 20px rgba(221, 42, 123, 0.35);
        }

        .instagram:hover {
            background-color: rgba(221, 42, 123, 0.7);
            box-shadow: inset 0 10px 18px -10px rgba(221, 42, 123, 0.55), inset 0 -10px 18px -10px rgba(221, 42, 123, 0.55), inset 12px 0 22px rgba(221, 42, 123, 0.45), inset -12px 0 22px rgba(221, 42, 123, 0.45), 0 0 10px rgba(221, 42, 123, 0.35);
        }

        #informationButton {
            position: absolute;
            top: 26px;
            width: 36px;
            height: 34px;
            line-height: 36px;
            font-family: Georgia, Verdana, serif;
            font-style: italic;
            font-weight: bold;
            font-size: 1.5rem;
            background: rgba(0, 30, 50, 0.5);
            border-left: 2px solid #00d5ff;
            border-right: 2px solid #00d5ff;
            border-radius: 50%;
            box-shadow: inset 6px 0 12px rgba(0, 213, 255, 0.25), inset -6px 0 12px rgba(0, 213, 255, 0.25);
            cursor: pointer;
            z-index: 999;
        }

        #informationButton:hover {
            background: rgba(0, 213, 255, 0.30) !important;
            border-color: #00d5ff !important;
        }

        #feedbackMsg {
            position: absolute;
            border-left: 5px solid rgba(0, 0, 0, 0.0);
            border-right: 5px solid rgba(0, 0, 0, 0.0);
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            font-size: 1rem;
            border-radius: 25px 7px;
            font-weight: 800;
            clear: both;
            padding: 2px 15px;
            height: 22px;
            line-height: 18px;
            bottom: 127px;
            max-width: 91%;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .msg {
            color: #44ff44;
            font-size: 0.8rem !important;
            font-style: italic;
            border-color: #00d5ff !important;
            background: rgba(0, 30, 50, 0.5);
        }

        .msg-error {
            color: white;
            font-size: 0.8rem !important;
            font-style: normal;
            border-color: #ff4444 !important;
            background-color: rgba(255, 68, 68, 0.3);
        }
        
        .msg-warning {
            color: white;
            font-size: 0.8rem !important;
            font-style: normal;
            border-color: #ffbb33 !important;
            background-color: rgba(255, 187, 51, 0.3);
        }

        .valid-input {
            border-color: #44ff44 !important;
            background-color: rgba(68, 255, 68, 0.3) !important;
            box-shadow: inset 0 10px 14px -10px rgba(68, 255, 68, 0.35), inset 0 -10px 14px -10px rgba(68, 255, 68, 0.35), inset 7px 0 14px rgba(68, 255, 68, 0.28), inset -7px 0 14px rgba(68, 255, 68, 0.28) !important;
        }
        
        .invalid-input {
            border-color: #ff4444 !important;
            background-color: rgba(255, 68, 68, 0.3) !important;
            box-shadow: inset 0 10px 14px -10px rgba(255, 68, 68, 0.35), inset 0 -10px 14px -10px rgba(255, 68, 68, 0.35), inset 7px 0 14px rgba(0, 213, 255, 0.28), inset -7px 0 14px rgba(255, 68, 68, 0.28) !important;
        }
        
        .footer {
            width: 100%;
            height: fit-content;
            display: inline-block;
            padding: 15px;
            border-radius: 25px 7px;
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            box-shadow: inset 0 14px 18px -10px rgba(0, 213, 255, 0.45), inset 0 -14px 18px -10px rgba(0, 213, 255, 0.45), inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
    </style>
    <script language="VBScript">
        Dim fso, shell
        Set fso = CreateObject("Scripting.FileSystemObject")
        Set shell = CreateObject("WScript.Shell")
        Const REG_PATH = "HKCU\Software\TDA Application\Glass Mode (GM) - TDA\"
        
        Sub LoadSettings()
            On Error Resume Next
            Dim val
            val = shell.RegRead(REG_PATH & "DataFile")
            If Err.Number = 0 Then document.getElementById("txtDataFile").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "LogFile")
            If Err.Number = 0 Then document.getElementById("txtLogFile").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpamChat")
            If Err.Number = 0 Then document.getElementById("txtSpamChat").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "RoomTitle")
            If Err.Number = 0 Then document.getElementById("txtRoomTitle").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "RoomPassword")
            If Err.Number = 0 Then document.getElementById("txtRoomPassword").value = val Else Err.Clear
            
            val = shell.RegRead(REG_PATH & "ServerNumber")
            If Err.Number = 0 Then 
                document.getElementById("txtServer").value = val
            Else
                document.getElementById("txtServer").value = "0"
                Err.Clear
            End If

            ValidateServerRange(document.getElementById("txtServer"))

            val = shell.RegRead(REG_PATH & "ChannelNumber")
            If Err.Number = 0 Then 
                document.getElementById("txtChannel").value = val
            Else
                document.getElementById("txtChannel").value = "0"
                Err.Clear
            End If

            val = shell.RegRead(REG_PATH & "MaxMatch")
            If Err.Number = 0 Then 
                document.getElementById("txtMaxMatch").value = val
            Else
                document.getElementById("txtMaxMatch").value = "0"
                Err.Clear
            End If

            val = shell.RegRead(REG_PATH & "TotalTB")
            If Err.Number = 0 Then 
                document.getElementById("txtTotalTB").value = val
            Else
                document.getElementById("txtTotalTB").value = "0"
                Err.Clear
            End If

            val = shell.RegRead(REG_PATH & "Round")
            If Err.Number = 0 Then 
                document.getElementById("txtRound").value = val
            Else
                document.getElementById("txtRound").value = "0"
                Err.Clear
            End If

            Dim inputs, i, regVal
            Set inputs = document.getElementsByTagName("input")
            For i = 0 To inputs.length - 1
                If inputs(i).type = "checkbox" And inputs(i).id <> "" Then
                    regVal = shell.RegRead(REG_PATH & inputs(i).id)
                    If Err.Number = 0 Then
                        inputs(i).checked = (regVal = "True")
                    Else
                        inputs(i).checked = False
                        Err.Clear
                    End If
                End If
            Next
            Err.Clear
            EnforceSingleRank
            UpdateServerLimit
        End Sub
        
        Sub ResetForm()
            If IsAllInputEmpty() Then
                ShowMessage "", ""
                Exit Sub
            End If
            document.getElementById("txtDataFile").value = ""
            document.getElementById("txtLogFile").value = ""
            document.getElementById("txtServer").value = "0"
            document.getElementById("txtChannel").value = "0"
            document.getElementById("txtMaxMatch").value = "0"
            document.getElementById("txtTotalTB").value = "0"
            document.getElementById("txtRound").value = "0"
            document.getElementById("txtSpamChat").value = ""
            document.getElementById("txtRoomTitle").value = ""
            document.getElementById("txtRoomPassword").value = ""
            Dim inputs, i
            Set inputs = document.getElementsByTagName("input")
            For i = 0 To inputs.length - 1
                If inputs(i).type = "checkbox" Then
                    inputs(i).checked = False
                End If
            Next

            ' --- Bersihkan semua class dari input yang memiliki validasi ---
            ClearValidationOnBlur document.getElementById("txtDataFile")
            ClearValidationOnBlur document.getElementById("txtLogFile")
            ClearValidationOnBlur document.getElementById("txtServer")
            ClearValidationOnBlur document.getElementById("txtChannel")
            ClearValidationOnBlur document.getElementById("txtMaxMatch")
            ClearValidationOnBlur document.getElementById("txtTotalTB")
            ClearValidationOnBlur document.getElementById("txtRound")
            ClearValidationOnBlur document.getElementById("txtSpamChat")
            ClearValidationOnBlur document.getElementById("txtRoomTitle")
            ClearValidationOnBlur document.getElementById("txtRoomPassword")

            EnforceSingleMode
            EnforceSingleRank
            UpdateServerLimit
            ' Jangan panggil ValidateServerRange di sini, karena akan memberi class
            ShowMessage "All configuration reseted", ""
        End Sub
        
        Sub HideInformation()
            document.getElementById("mainContent").style.display = "block"
            document.getElementById("informationContent").style.display = "none"
            ShowMessage "", ""
        End Sub
        
        Sub ShowInformation()
            document.getElementById("mainContent").style.display = "none"
            document.getElementById("informationContent").style.display = "block"
            ShowMessage "", ""
        End Sub

        Sub ServerUp()
            Dim val, num
            val = Trim(document.getElementById("txtServer").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num + 1
            If num > 8 Then num = 0
            document.getElementById("txtServer").value = num
            UpdateServerLimit
        End Sub

        Sub ServerDown()
            Dim val, num
            val = Trim(document.getElementById("txtServer").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num - 1
            If num < 0 Then num = 8
            document.getElementById("txtServer").value = num
            UpdateServerLimit
        End Sub

        Sub ChannelUp()
            Dim val, num
            val = Trim(document.getElementById("txtChannel").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num + 1
            If num > 10 Then num = 0
            document.getElementById("txtChannel").value = num
            ValidateFields 0, document.getElementById("txtChannel")
        End Sub

        Sub ChannelDown()
            Dim val, num
            val = Trim(document.getElementById("txtChannel").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num - 1
            If num < 0 Then num = 10
            document.getElementById("txtChannel").value = num
            ValidateFields 0, document.getElementById("txtChannel")
        End Sub
    
        Sub MaxMatchUp()
            Dim val, num
            val = Trim(document.getElementById("txtMaxMatch").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num + 1
            If num > 1000 Then num = 1
            document.getElementById("txtMaxMatch").value = num
            ValidateFields 0, document.getElementById("txtMaxMatch")
        End Sub

        Sub MaxMatchDown()
            Dim val, num
            val = Trim(document.getElementById("txtMaxMatch").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num - 1
            If num < 1 Then num = 1000
            document.getElementById("txtMaxMatch").value = num
            ValidateFields 0, document.getElementById("txtMaxMatch")
        End Sub

        Sub TotalTBUp()
            Dim val, num
            val = Trim(document.getElementById("txtTotalTB").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num + 1
            If num > 8 Then num = 0
            document.getElementById("txtTotalTB").value = num
            ValidateFields 0, document.getElementById("txtTotalTB")
        End Sub

        Sub TotalTBDown()
            Dim val, num
            val = Trim(document.getElementById("txtTotalTB").value)
            If IsNumeric(val) Then
                num = CInt(val)
            Else
                num = 0
            End If
            num = num - 1
            If num < 0 Then num = 8
            document.getElementById("txtTotalTB").value = num
            ValidateFields 0, document.getElementById("txtTotalTB")
        End Sub

        Function GetArrayIndex(arr, target)
            Dim i
            For i = 0 To UBound(arr)
                If arr(i) = target Then
                    GetArrayIndex = i
                    Exit Function
                End If
            Next
            GetArrayIndex = -1
        End Function

        Sub RoundUp()
            Dim rounds, idx, num
            rounds = Array(0, 3, 5, 7, 9)
            If IsNumeric(document.getElementById("txtRound").value) Then
                num = CInt(document.getElementById("txtRound").value)
            Else
                num = 0
            End If
            idx = GetArrayIndex(rounds, num)
            If idx = -1 Then idx = 0
            document.getElementById("txtRound").value = rounds((idx + 1) Mod 5)
            ValidateFields 0, document.getElementById("txtRound")
        End Sub

        Sub RoundDown()
            Dim rounds, idx, num
            rounds = Array(0, 3, 5, 7, 9)
            If IsNumeric(document.getElementById("txtRound").value) Then
                num = CInt(document.getElementById("txtRound").value)
            Else
                num = 0
            End If
            idx = GetArrayIndex(rounds, num)
            If idx = -1 Then idx = 0
            If idx = 0 Then
                idx = UBound(rounds)
            Else
                idx = idx - 1
            End If
            document.getElementById("txtRound").value = rounds(idx)
            ValidateFields 0, document.getElementById("txtRound")
        End Sub
        
        Sub UpdateServerLimit()
            Dim maxVal, serverVal, serverNum
            Dim isTraining, isBeginner, isExpert, isClan, isPublic

            isTraining = document.getElementById("chkTraining").Checked
            isBeginner = document.getElementById("chkBeginner").Checked
            isExpert = document.getElementById("chkExpert").Checked
            isClan = document.getElementById("chkClan").Checked
            isPublic = document.getElementById("chkPublic").Checked

            If isTraining Or isBeginner Or isExpert Or isClan Then
                maxVal = 2
            Else
                maxVal = 8
            End If

            serverVal = Trim(document.getElementById("txtServer").value)
            If IsNumeric(serverVal) Then
                serverNum = CInt(serverVal)
                If serverNum > maxVal Then
                    document.getElementById("txtServer").value = maxVal
                End If
            End If

            ' Perbarui tampilan validasi
            ValidateServerRange document.getElementById("txtServer")
        End Sub

        ' --------------------- Rank Server (hanya 1) ---------------------
        Sub EnforceSingleRank()
            Dim rankIds, i, checkedCount, firstChecked
            rankIds = Array("chkTraining", "chkBeginner", "chkPublic", "chkExpert", "chkClan")
            checkedCount = 0
            firstChecked = ""
            For i = 0 To UBound(rankIds)
                If document.getElementById(rankIds(i)).checked Then
                    checkedCount = checkedCount + 1
                    If firstChecked = "" Then firstChecked = rankIds(i)
                End If
            Next
            If checkedCount > 1 Then
                ' Uncheck semua, lalu cek hanya yang pertama ditemukan
                For i = 0 To UBound(rankIds)
                    document.getElementById(rankIds(i)).checked = False
                Next
                If firstChecked <> "" Then
                    document.getElementById(firstChecked).checked = True
                End If
            End If
        End Sub

        ' --------------- Mode (hanya 1) ---------------
        Sub EnforceSingleMode()
            Dim modeIds, i, checkedCount, firstChecked
            modeIds = Array("chkTb2_8", "chkJob2_8", "chkTbRoomMaster", "chkJobRoomMaster")
            checkedCount = 0
            firstChecked = ""
            For i = 0 To UBound(modeIds)
                If document.getElementById(modeIds(i)).checked Then
                    checkedCount = checkedCount + 1
                    If firstChecked = "" Then firstChecked = modeIds(i)
                End If
            Next
            If checkedCount > 1 Then
                ' Uncheck semua, lalu centang hanya yang pertama ditemukan
                For i = 0 To UBound(modeIds)
                    document.getElementById(modeIds(i)).checked = False
                Next
                If firstChecked <> "" Then
                    document.getElementById(firstChecked).checked = True
                End If
            End If
        End Sub

        Sub ModeCheckboxClicked(id)
            Dim el
            Set el = document.getElementById(id)
            If el.checked Then
                ' Uncheck semua mode lainnya
                Dim modeIds, i
                modeIds = Array("chkTb2_8", "chkJob2_8", "chkTbRoomMaster", "chkJobRoomMaster")
                For i = 0 To UBound(modeIds)
                    If modeIds(i) <> id Then
                        document.getElementById(modeIds(i)).checked = False
                    End If
                Next
            End If
        End Sub

        Sub RankCheckboxClicked(id)
            Dim el
            Set el = document.getElementById(id)
            If el.checked Then
                ' Jika dicentang, uncheck semua rank lainnya
                Dim rankIds, i
                rankIds = Array("chkTraining", "chkBeginner", "chkPublic", "chkExpert", "chkClan")
                For i = 0 To UBound(rankIds)
                    If rankIds(i) <> id Then
                        document.getElementById(rankIds(i)).checked = False
                    End If
                Next
            End If
            ' Update batas server
            UpdateServerLimit
        End Sub

        Sub MapCheckboxClicked(id)
            Dim el
            Set el = document.getElementById(id)
            If el.checked Then
                ' Uncheck semua mode lainnya
                Dim modeIds, i
                modeIds = Array("chkGlassLab", "chkGlassUpdown", "chkRandomMap")
                For i = 0 To UBound(modeIds)
                    If modeIds(i) <> id Then
                        document.getElementById(modeIds(i)).checked = False
                    End If
                Next
            End If
        End Sub

        Function ValidateServerRange(targetEl)
            Dim val, num, maxVal, isValid
            val = Trim(document.getElementById("txtServer").value)

            ' Tentukan maxVal berdasarkan rank
            Dim isTraining, isBeginner, isExpert, isClan, isPublic
            isTraining = document.getElementById("chkTraining").Checked
            isBeginner = document.getElementById("chkBeginner").Checked
            isExpert = document.getElementById("chkExpert").Checked
            isClan = document.getElementById("chkClan").Checked
            isPublic = document.getElementById("chkPublic").Checked

            If isTraining Or isBeginner Or isExpert Or isClan Then
                maxVal = 2
            Else
                maxVal = 8
            End If

            If Not (targetEl Is Nothing) Then
                ' Jika kosong atau "0" -> hapus class dan hilangkan pesan
                If val = "" Or val = "0" Then
                    targetEl.className = ""
                    ShowMessage "", ""
                    ValidateServerRange = True
                    Exit Function
                End If

                ' Validasi numerik dan range
                If IsNumeric(val) Then
                    num = CInt(val)
                    If num >= 1 And num <= maxVal Then
                        ShowMessage val, ""
                        targetEl.className = "valid-input"
                        isValid = True
                    Else
                        ShowMessage "Server must be between 1 and " & maxVal, "msg-error"
                        targetEl.className = "invalid-input"
                        isValid = False
                    End If
                Else
                    ShowMessage "Server must be numeric", "msg-error"
                    targetEl.className = "invalid-input"
                    isValid = False
                End If
                ValidateServerRange = isValid
            Else
                ValidateServerRange = True
            End If
        End Function

        Function IsAllInputEmpty()
            Dim val
            On Error Resume Next  ' Tangani error konversi CInt
            val = Trim(document.getElementById("txtDataFile").value)
            If val <> "" Then IsAllInputEmpty = False : Exit Function
            val = Trim(document.getElementById("txtLogFile").value)
            If val <> "" Then IsAllInputEmpty = False : Exit Function
            val = Trim(document.getElementById("txtSpamChat").value)
            If val <> "" Then IsAllInputEmpty = False : Exit Function

            ' --- Server ---
            val = Trim(document.getElementById("txtServer").value)
            If val <> "" Then
                Dim numServer
                numServer = CInt(val)
                If Err.Number = 0 Then
                    If numServer <> 0 Then IsAllInputEmpty = False : Exit Function
                Else
                    ' Jika error konversi, berarti bukan angka -> dianggap tidak kosong
                    IsAllInputEmpty = False
                    Err.Clear
                    Exit Function
                End If
            End If

            ' --- Channel ---
            val = Trim(document.getElementById("txtChannel").value)
            If val <> "" Then
                Dim numChannel
                numChannel = CInt(val)
                If Err.Number = 0 Then
                    If numChannel <> 0 Then IsAllInputEmpty = False : Exit Function
                Else
                    IsAllInputEmpty = False
                    Err.Clear
                    Exit Function
                End If
            End If

            ' --- Max Match ---
            val = Trim(document.getElementById("txtMaxMatch").value)
            If val <> "" Then
                Dim numMatch
                numMatch = CInt(val)
                If Err.Number = 0 Then
                    If numMatch <> 0 Then IsAllInputEmpty = False : Exit Function
                Else
                    IsAllInputEmpty = False
                    Err.Clear
                    Exit Function
                End If
            End If

            ' --- Total TB ---
            val = Trim(document.getElementById("txtTotalTB").value)
            If val <> "" Then
                Dim numTotalTB
                numTotalTB = CInt(val)
                If Err.Number = 0 Then
                    If numTotalTB <> 0 Then IsAllInputEmpty = False : Exit Function
                Else
                    IsAllInputEmpty = False
                    Err.Clear
                    Exit Function
                End If
            End If

            ' --- Round ---
            val = Trim(document.getElementById("txtRound").value)
            If val <> "" Then
                Dim numRound
                numRound = CInt(val)
                If Err.Number = 0 Then
                    If numRound <> 0 Then IsAllInputEmpty = False : Exit Function
                Else
                    IsAllInputEmpty = False
                    Err.Clear
                    Exit Function
                End If
            End If

            val = Trim(document.getElementById("txtRoomTitle").value)
            If val <> "" Then IsAllInputEmpty = False : Exit Function
            val = Trim(document.getElementById("txtRoomPassword").value)
            If val <> "" Then IsAllInputEmpty = False : Exit Function

            Dim chk
            Set chk = document.getElementById("chkTb2_8")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkJob2_8")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkTbRoomMaster")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkJobRoomMaster")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkTraining")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkPublic")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkExpert")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkBeginner")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkClan")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkGlassLab")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkGlassUpdown")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkRandomMap")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkExpUp")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkLog")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkPointUp")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkNoSpamChat")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkExpBattlePass")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function

            On Error GoTo 0
            IsAllInputEmpty = True
        End Function
        
        Function ValidateModeRequired()
            If IsAllInputEmpty() Then
                ValidateModeRequired = True
                Exit Function
            End If
        
            Dim modeCount, modeSelected
            modeCount = 0
            modeSelected = ""
        
            If document.getElementById("chkTb2_8").Checked Then modeCount = modeCount + 1
            If document.getElementById("chkJob2_8").Checked Then modeCount = modeCount + 1
            If document.getElementById("chkTbRoomMaster").Checked Then modeCount = modeCount + 1
            If document.getElementById("chkJobRoomMaster").Checked Then modeCount = modeCount + 1
        
            If modeCount = 0 Then
                ShowMessage "Please select at least 1 mode", "msg-warning"
                document.body.Focus
                document.getElementById("mainPanel").scrollTop = document.getElementById("selectModes").offsetTop
                ValidateModeRequired = False
                Exit Function
            End If
        
            ValidateModeRequired = True
        End Function
        
        Function ValidateMapRequired()
            If IsAllInputEmpty() Then
                ValidateMapRequired = True
                Exit Function
            End If

            ' Cek mode yang dipilih
            Dim isRoomMaster
            isTbMode = False
            If document.getElementById("chkJobRoomMaster").Checked Then isRoomMaster = True
            If document.getElementById("chkTbRoomMaster").Checked Then isRoomMaster = True

            ' Jika mode Tb, maka map WAJIB dipilih
            If isRoomMaster Then
                Dim mapCount
                mapCount = 0
                If document.getElementById("chkGlassLab").Checked Then mapCount = mapCount + 1
                If document.getElementById("chkGlassUpdown").Checked Then mapCount = mapCount + 1
                If document.getElementById("chkRandomMap").Checked Then mapCount = mapCount + 1

                If mapCount = 0 Then
                    ShowMessage "Please select at least 1 map (required for Room Master)", "msg-warning"
                    document.body.Focus
                    document.getElementById("mainPanel").scrollTop = document.getElementById("selectMaps").offsetTop
                    ValidateMapRequired = False
                    Exit Function
                End If
            End If
            ValidateMapRequired = True
        End Function
        
        Sub SetDataFile()
            Dim txtDataFileEl
            Set txtDataFileEl = document.getElementById("txtDataFile")
            txtDataFileEl.value = document.getElementById("fileData").value
            ValidateDataFile txtDataFileEl
            txtDataFileEl.className = ""
        End Sub

        Sub SetLogFile()
            Dim txtLogFileEl
            Set txtLogFileEl = document.getElementById("txtLogFile")
            txtLogFileEl.value = document.getElementById("fileLog").value
            ValidateLogFile txtLogFileEl
            txtLogFileEl.className = ""
        End Sub

        Function ValidateDataFile(targetEl)
            Dim path, fsoLocal, fileName, ext
            Dim isValid
            Set fsoLocal = CreateObject("Scripting.FileSystemObject")
            path = Trim(document.getElementById("txtDataFile").value)
            fileName = fsoLocal.GetBaseName(path)
            ext = LCase(fsoLocal.GetExtensionName(path))
            
            If Not IsEmpty(targetEl) Then targetEl.className = ""
            
            If path = "" Then
                ShowMessage "", ""
                isValid = True
            Else
                If Not fsoLocal.FileExists(path) Then
                    ShowMessage "Invalid file: " & path, "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf ext <> "txt" Then
                    ShowMessage "Please select "".txt"" file (" & fileName & """." & ext & """)", "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf Trim(document.getElementById("txtLogFile").value) <> "" And path = Trim(document.getElementById("txtLogFile").value) Then
                    ShowMessage "Log file: " & path, "msg-error"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                Else
                    ShowMessage path, ""
                    isValid = True
                    If Not IsEmpty(targetEl) Then targetEl.className = "valid-input"
                End If
            End If
            
            ValidateDataFile = isValid
        End Function

        Function ValidateLogFile(targetEl)
            Dim path, fsoLocal, fileName, ext
            Dim isValid
            Set fsoLocal = CreateObject("Scripting.FileSystemObject")
            path = Trim(document.getElementById("txtLogFile").value)
            fileName = fsoLocal.GetBaseName(path)
            ext = LCase(fsoLocal.GetExtensionName(path))
            
            If Not IsEmpty(targetEl) Then targetEl.className = ""
            
            If path = "" Then
                ShowMessage "", ""
                isValid = True
            Else
                If Not fsoLocal.FileExists(path) Then
                    ShowMessage "Invalid file: " & path, "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf ext <> "txt" And ext <> "log" Then
                    ShowMessage "Please select "".txt""/"".log"" file (" & fileName & """." & ext & """)", "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf Trim(document.getElementById("txtDataFile").value) <> "" And path = Trim(document.getElementById("txtDataFile").value) Then
                    ShowMessage "Data file: " & path, "msg-error"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                Else
                    ShowMessage path, ""
                    isValid = True
                    If Not IsEmpty(targetEl) Then targetEl.className = "valid-input"
                End If
            End If
            
            ValidateLogFile = isValid
        End Function
        
        Function ValidateFields(mode, targetEl)
            Dim fields, i, el, val, minLen, maxLen, isOpt, fieldId, fieldName
            Dim isValid, j, ch, allowedChars, hasInvalidChar, invalidChars
            Dim isFinal
            Dim numericFields, isNumericField, k
            isFinal = (mode = 1)
            
            numericFields = Array("txtServer", "txtChannel", "txtMaxMatch", "txtTotalTB", "txtRound")
            
            fields = Array( _
                "txtSpamChat", "SpamChat", 3, 120, True, _
                "txtServer", "Server", 1, 1, False, _
                "txtChannel", "Channel", 1, 2, False, _
                "txtMaxMatch", "Max Match", 1, 4, False, _
                "txtTotalTB", "Total TB", 1, 1, False, _
                "txtRound", "Round", 1, 1, False, _
                "txtRoomTitle", "Room Title", 1, 20, True, _
                "txtRoomPassword", "Room Password", 1, 4, True _
            )
            
            If isFinal Then
                For i = 0 To UBound(fields) Step 5
                    fieldId = fields(i)
                    fieldName = fields(i+1)
                    minLen = fields(i+2)
                    maxLen = fields(i+3)
                    isOpt = fields(i+4)
                    Set el = document.getElementById(fieldId)
                    val = Trim(el.value)
                    
                    isNumericField = False
                    For k = 0 To UBound(numericFields)
                        If numericFields(k) = fieldId Then isNumericField = True : Exit For
                    Next
                    
                    If isOpt And val = "" Then
                        ' skip
                    ElseIf isNumericField And (val = "" Or val = "0") Then
                        ' Dianggap kosong, tidak perlu validasi
                    Else
                        If Len(val) < minLen Then
                            ShowMessage fieldName & ": Too short (" & Len(val) & " char, min " & minLen & ")", "msg-error"
                            el.focus
                            ValidateFields = False
                            Exit Function
                        ElseIf Len(val) > maxLen Then
                            ShowMessage fieldName & ": Too long (" & Len(val) & " char, max " & maxLen & ")", "msg-error"
                            el.focus
                            ValidateFields = False
                            Exit Function
                        End If
                    End If
                    
                    If Not (isOpt And val = "") Then
                        If Not (isNumericField And val = "0") Then
                            allowedChars = GetAllowedChars(fieldId)
                            If allowedChars <> "" Then
                                hasInvalidChar = False
                                invalidChars = ""
                                For j = 1 To Len(val)
                                    ch = Mid(val, j, 1)
                                    If InStr(1, allowedChars, ch, 1) = 0 Then
                                        hasInvalidChar = True
                                        If InStr(invalidChars, ch) = 0 Then
                                            invalidChars = invalidChars & ch
                                        End If
                                    End If
                                Next
                                If hasInvalidChar Then
                                    ShowMessage "Invalid character (" & fieldName & "): " & invalidChars, "msg-error"
                                    el.focus
                                    ValidateFields = False
                                    Exit Function
                                End If
                            End If
                        End If
                        
                        If isNumericField And val <> "" And val <> "0" Then
                            Dim rangeValid2, minVal2, maxVal2, numVal2
                            rangeValid2 = True
                            Select Case fieldId
                                Case "txtChannel"
                                    minVal2 = 0 : maxVal2 = 10
                                Case "txtRound"
                                    If IsNumeric(val) Then
                                        numVal2 = CInt(val)
                                        If Not (numVal2 = 0 Or numVal2 = 3 Or numVal2 = 5 Or numVal2 = 7 Or numVal2 = 9) Then
                                            rangeValid2 = False
                                            ShowMessage fieldName & ": must be 0,3,5,7,9", "msg-error"
                                        End If
                                    Else
                                        rangeValid2 = False
                                    End If
                                Case "txtTotalTB"
                                    minVal2 = 0 : maxVal2 = 8
                                Case "txtMaxMatch"
                                    minVal2 = 1 : maxVal2 = 1000
                                Case Else
                                    ' tidak ada range
                            End Select
                            
                            If rangeValid2 = False Then
                                isValid = False
                                targetEl.className = "invalid-input"
                                ValidateFields = False
                                Exit Function
                            ElseIf rangeValid2 = True And (fieldId = "txtChannel" Or fieldId = "txtTotalTB" Or fieldId = "txtMaxMatch") Then
                                If IsNumeric(val) Then
                                    numVal2 = CInt(val)
                                    If numVal2 < minVal2 Or numVal2 > maxVal2 Then
                                        rangeValid2 = False
                                        ShowMessage fieldName & ": must be between " & minVal2 & " and " & maxVal2, "msg-error"
                                        isValid = False
                                        targetEl.className = "invalid-input"
                                        ValidateFields = False
                                        Exit Function
                                    End If
                                Else
                                    rangeValid2 = False
                                    isValid = False
                                    targetEl.className = "invalid-input"
                                    ValidateFields = False
                                    Exit Function
                                End If
                            End If
                        End If
                    End If
                Next
                ValidateFields = True
                Exit Function
            End If
            
            ' Mode non-final (per-field)
            For i = 0 To UBound(fields) Step 5
                fieldId = fields(i)
                fieldName = fields(i+1)
                minLen = fields(i+2)
                maxLen = fields(i+3)
                isOpt = fields(i+4)
                
                Set el = document.getElementById(fieldId)
                val = Trim(el.value)
                
                If Not IsEmpty(targetEl) And fieldId = targetEl.id Then
                    isNumericField = False
                    For k = 0 To UBound(numericFields)
                        If numericFields(k) = fieldId Then isNumericField = True : Exit For
                    Next
                    
                    If Not IsEmpty(targetEl) Then targetEl.className = ""
                    
                    ' Jika kosong atau "0" untuk numerik => hapus class dan pesan
                    If val = "" Or (isNumericField And val = "0") Then
                        ShowMessage "", ""
                        isValid = True
                        targetEl.className = ""
                        ValidateFields = True
                        Exit Function
                    End If
                    
                    ' Cek panjang
                    If Len(val) < minLen Then
                        ShowMessage fieldName & ": Too short (" & Len(val) & " char, min " & minLen & ")", "msg-error"
                        isValid = False
                        targetEl.className = "invalid-input"
                    ElseIf Len(val) > maxLen Then
                        ShowMessage fieldName & ": Too long (" & Len(val) & " char, max " & maxLen & ")", "msg-error"
                        isValid = False
                        targetEl.className = "invalid-input"
                    Else
                        allowedChars = GetAllowedChars(fieldId)
                        If allowedChars <> "" Then
                            hasInvalidChar = False
                            invalidChars = ""
                            For j = 1 To Len(val)
                                ch = Mid(val, j, 1)
                                If InStr(1, allowedChars, ch, 1) = 0 Then
                                    hasInvalidChar = True
                                    If InStr(invalidChars, ch) = 0 Then
                                        invalidChars = invalidChars & ch
                                    End If
                                End If
                            Next
                            If hasInvalidChar Then
                                ShowMessage "Invalid character (" & fieldName & "): " & invalidChars, "msg-error"
                                isValid = False
                                targetEl.className = "invalid-input"
                                ValidateFields = False
                                Exit Function
                            End If
                        End If

                        ' Range khusus untuk numerik (kecuali "0" sudah tertangani di atas)
                        If isNumericField Then
                            Dim rangeValid, minVal, maxVal, numVal
                            rangeValid = True
                            Select Case fieldId
                                Case "txtChannel"
                                    minVal = 0 : maxVal = 10
                                Case "txtRound"
                                    If IsNumeric(val) Then
                                        numVal = CInt(val)
                                        If Not (numVal = 0 Or numVal = 3 Or numVal = 5 Or numVal = 7 Or numVal = 9) Then
                                            rangeValid = False
                                            ShowMessage fieldName & ": must be 0,3,5,7,9", "msg-error"
                                        End If
                                    Else
                                        rangeValid = False
                                    End If
                                Case "txtTotalTB"
                                    minVal = 0 : maxVal = 8
                                Case "txtMaxMatch"
                                    minVal = 1 : maxVal = 1000
                                Case Else
                                    ' tidak ada range
                            End Select

                            If rangeValid = False Then
                                isValid = False
                                targetEl.className = "invalid-input"
                                ValidateFields = False
                                Exit Function
                            ElseIf rangeValid = True And (fieldId = "txtChannel" Or fieldId = "txtTotalTB" Or fieldId = "txtMaxMatch") Then
                                If IsNumeric(val) Then
                                    numVal = CInt(val)
                                    If numVal < minVal Or numVal > maxVal Then
                                        rangeValid = False
                                        ShowMessage fieldName & ": must be between " & minVal & " and " & maxVal, "msg-error"
                                        isValid = False
                                        targetEl.className = "invalid-input"
                                        ValidateFields = False
                                        Exit Function
                                    End If
                                Else
                                    rangeValid = False
                                    isValid = False
                                    targetEl.className = "invalid-input"
                                    ValidateFields = False
                                    Exit Function
                                End If
                            End If
                        End If

                        ' Lolos semua validasi
                        ShowMessage val, ""
                        isValid = True
                        targetEl.className = "valid-input"
                    End If
                    ValidateFields = isValid
                    Exit Function
                End If
            Next
            
            ValidateFields = True
        End Function

        Function GetAllowedChars(fieldId)
            Select Case fieldId
                Case "txtServer", "txtChannel", "txtMaxMatch", "txtTotalTB"
                    GetAllowedChars = "0123456789"
                Case "txtRound"
                    GetAllowedChars = "03579"
                Case "txtSpamChat", "txtRoomTitle"
                    GetAllowedChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789 !?%&*/\@-().,_|:"
                Case Else
                    GetAllowedChars = ""
            End Select
        End Function

        Sub clearValidationClass(el)
            If Not IsEmpty(el) Then
                el.className = ""
            End If
        End Sub
        
        Sub ClearValidationOnBlur(el)
            If Not IsEmpty(el) Then
                el.className = ""
            End If
            ShowMessage "", ""
        End Sub
        
        Sub StartExeScript()
            Path = "C:\Script - TDA\GB Glass Mode - TDA\Start GB Glass Mode (GM) - TDA.exe"
            If fso.FileExists(Path) Then
                SaveConfiguration()
                shell.Run Chr(34) & Path & Chr(34), 1, False
                self.close()
            End If
            ShowMessage "Script not found", "msg-error"
        End Sub
        
        Sub SaveSettings()
            On Error Resume Next
            document.body.Focus
            shell.RegWrite REG_PATH & "DataFile", document.getElementById("txtDataFile").value, "REG_SZ"
            shell.RegWrite REG_PATH & "LogFile", document.getElementById("txtLogFile").value, "REG_SZ"
            shell.RegWrite REG_PATH & "ServerNumber", document.getElementById("txtServer").value, "REG_SZ"
            shell.RegWrite REG_PATH & "ChannelNumber", document.getElementById("txtChannel").value, "REG_SZ"
            shell.RegWrite REG_PATH & "MaxMatch", document.getElementById("txtMaxMatch").value, "REG_SZ"
            shell.RegWrite REG_PATH & "TotalTB", document.getElementById("txtTotalTB").value, "REG_SZ"
            shell.RegWrite REG_PATH & "Round", document.getElementById("txtRound").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpamChat", document.getElementById("txtSpamChat").value, "REG_SZ"
            shell.RegWrite REG_PATH & "RoomTitle", document.getElementById("txtRoomTitle").value, "REG_SZ"
            shell.RegWrite REG_PATH & "RoomPassword", document.getElementById("txtRoomPassword").value, "REG_SZ"
            
            Dim inputs, i
            Set inputs = document.getElementsByTagName("input")
            For i = 0 To inputs.length - 1
                If inputs(i).type = "checkbox" And inputs(i).id <> "" Then
                    If inputs(i).checked Then
                        shell.RegWrite REG_PATH & inputs(i).id, "True", "REG_SZ"
                    Else
                        shell.RegWrite REG_PATH & inputs(i).id, "False", "REG_SZ"
                    End If
                End If
            Next
        
            If Err.Number <> 0 Then
                ShowMessage "Something wrong during save", "msg-error"
                Err.Clear
            End If
        End Sub

        Sub DeleteAllRegistry()
            On Error Resume Next
            Dim arrKeys, i
            arrKeys = Array("DataFile", "LogFile", "ServerNumber", "ChannelNumber", "MaxMatch", "Round", "TotalTB", "SpamChat", "RoomTitle", "RoomPassword", "chkTb2_8", "chkJob2_8", "chkTbRoomMaster", "chkJobRoomMaster", "chkTraining", "chkBeginner", "chkPublic", "chkExpert", "chkClan", "chkGlassLab", "chkGlassUpdown", "chkRandomMap", "chkLog", "chkExpUp", "chkPointUp", "chkNoSpamChat", "chkExpBattlePass")
            For i = 0 To UBound(arrKeys)
                shell.RegDelete REG_PATH & arrKeys(i)
            Next
            If Err.Number <> 0 Then Err.Clear
        End Sub
                
        Sub SaveConfiguration()
            document.body.Focus

            ' Cek apakah semua field kosong (tidak perlu simpan)
            If IsAllInputEmpty() Then
                DeleteAllRegistry
                ShowMessage "", ""
                Exit Sub
            End If

            ' ===== TAMBAHKAN VALIDASI SEMUA FIELD =====
            If ValidateFields(1, Nothing) = False Then
                Exit Sub   ' gagal validasi, batalkan simpan
            End If

            ' Validasi mode (hanya boleh pilih satu)
            If ValidateModeRequired() = False Then Exit Sub

            ' Validasi Map (hanya boleh pilih satu)
            If ValidateMapRequired() = False Then Exit Sub

            ' Validasi file Data & Log
            If ValidateDataFile(document.getElementById("txtDataFile")) = False Then Exit Sub
            If ValidateLogFile(document.getElementById("txtLogFile")) = False Then Exit Sub

            ' ... lanjutkan konversi dan validasi numerik (Server, Channel, MaxMatch) seperti semula ...
            Dim serverVal, channelVal, matchVal
            Dim serverNum, channelNum, matchNum

            serverVal = Trim(document.getElementById("txtServer").value)
            channelVal = Trim(document.getElementById("txtChannel").value)
            matchVal = Trim(document.getElementById("txtMaxMatch").value)
            totalTBVal = Trim(document.getElementById("txtTotalTB").value)
            roundVal = Trim(document.getElementById("txtRound").value)

            On Error Resume Next
            serverNum = CInt(serverVal)
            If Err.Number <> 0 Then
                ShowMessage "Server must be numeric", "msg-error"
                document.getElementById("txtServer").focus
                Err.Clear
                Exit Sub
            End If

            channelNum = CInt(channelVal)
            If Err.Number <> 0 Then
                ShowMessage "Channel must be numeric", "msg-error"
                document.getElementById("txtChannel").focus
                Err.Clear
                Exit Sub
            End If

            matchNum = CInt(matchVal)
            If Err.Number <> 0 Then
                ShowMessage "Max Match must be numeric", "msg-error"
                document.getElementById("txtMaxMatch").focus
                Err.Clear
                Exit Sub
            End If
            On Error GoTo 0

            totalTBNum = CInt(totalTBVal)
            If Err.Number <> 0 Then
                ShowMessage "Total TB must be numeric", "msg-error"
                document.getElementById("txtTotalTB").focus
                Err.Clear
                Exit Sub
            End If

            roundNum = CInt(roundVal)
            If Err.Number <> 0 Then
                ShowMessage "Round must be numeric", "msg-error"
                document.getElementById("txtRound").focus
                Err.Clear
                Exit Sub
            End If

            ' Cek tidak boleh 0
            If serverNum = 0 Then
                ShowMessage "Server cannot be 0", "msg-error"
                document.getElementById("txtServer").focus
                Exit Sub
            End If

            If channelNum = 0 Then
                ShowMessage "Channel cannot be 0", "msg-error"
                document.getElementById("txtChannel").focus
                Exit Sub
            End If

            Dim isRoomMaster
            isRoomMaster = document.getElementById("chkTbRoomMaster").Checked Or document.getElementById("chkJobRoomMaster").Checked

            If isRoomMaster Then
                If totalTBNum = 0 Then
                    ShowMessage "Total TB cannot be 0 for Room Master mode", "msg-error"
                    document.getElementById("txtTotalTB").focus
                    Exit Sub
                End If
                If roundNum = 0 Then
                    ShowMessage "Round cannot be 0 for Room Master mode", "msg-error"
                    document.getElementById("txtRound").focus
                    Exit Sub
                End If
            End If

            ' --- Validasi batas Server berdasarkan rank ---
            Dim maxVal
            Dim isTraining2, isBeginner2, isExpert2, isClan2, isPublic2
            isTraining2 = document.getElementById("chkTraining").Checked
            isBeginner2 = document.getElementById("chkBeginner").Checked
            isExpert2 = document.getElementById("chkExpert").Checked
            isClan2 = document.getElementById("chkClan").Checked
            isPublic2 = document.getElementById("chkPublic").Checked

            If isTraining2 Or isBeginner2 Or isExpert2 Or isClan2 Then
                maxVal = 2
            Else
                maxVal = 8
            End If

            If serverNum < 1 Or serverNum > maxVal Then
                ShowMessage "Server must be between 1 and " & maxVal, "msg-error"
                document.getElementById("txtServer").focus
                Exit Sub
            End If

            ' Simpan ke registry
            SaveSettings
            ShowMessage "Configuration saved", ""
        End Sub
        
        Sub ShowMessage(msg, typeClass)
            Dim feedback
            Set feedback = document.getElementById("feedbackMsg")
            if msg = "" Then
                feedback.style.display = "none"
            Else
                feedback.style.display = "block"
                feedback.innerHTML = msg
                feedback.className = "msg " & typeClass
            End If
            window.CenterFeedback
        End Sub
    </script>
</head>

<body>
    <div class="container" id="mainContent" style="display: block;">
        <h3>Game Boost Glass Mode Settings</h3>
        <div id="mainPanel" style="height: 194px; background: rgba(0, 30, 50, 0.5);">
            <div style="display: inline-block;">
                <div class="header" style="display: table;">Data File</div>
                <input title="Input Data File" type="text" id="txtDataFile" style="display: inline-block; width: 249px;" onkeyup="ValidateDataFile(this)" onkeypress="ValidateDataFile(this)" onblur="ClearValidationOnBlur(this)"/>
                <button title="Ctrl + F Then D" type="button" id="btnBrowseDataFile" onclick="document.getElementById('fileData').click()">Browse Data File</button>
                <input type="file" id="fileData" style="display:none" onchange="SetDataFile()"/>
            </div>
            <div style="display: inline-block;">
                <div class="header" style="display: table;">Log File</div>
                <input title="Input Log File" type="text" id="txtLogFile" style="display: inline-block; width: 249px;" onkeyup="ValidateLogFile(this)" onkeypress="ValidateLogFile(this)" onblur="ClearValidationOnBlur(this)"/>
                <button title="Ctrl + F Then L" type="button" id="btnBrowseLogFile" onclick="document.getElementById('fileLog').click()">Browse Log File</button>
                <input type="file" id="fileLog" style="display:none" onchange="SetLogFile()"/>
            </div>
            <div id="selectModes" style="width: 49%; display: inline-block;">
                <div class="header" style="margin: 0;">Modes</div>
                <div class="list-content">
                    <input type="checkbox" id="chkTb2_8" onclick="ModeCheckboxClicked(this.id)">
                    <label for="chkTb2_8">Tb 2 ~ 8</label>
                    <input type="checkbox" id="chkJob2_8" onclick="ModeCheckboxClicked(this.id)">
                    <label for="chkJob2_8">Job 2 ~ 8</label>
                    <input type="checkbox" id="chkTbRoomMaster" onclick="ModeCheckboxClicked(this.id)">
                    <label for="chkTbRoomMaster">Tb Room Master</label>
                    <input type="checkbox" id="chkJobRoomMaster" onclick="ModeCheckboxClicked(this.id)">
                    <label for="chkJobRoomMaster">Job Room Master</label>
                </div>
            </div>
            <div id="selectRankServer" style="width: 49%; display: inline-block;">
                <div class="header" style="margin: 0;">Rank Server</div>
                <div class="list-content">
                    <input type="checkbox" id="chkTraining" onclick="RankCheckboxClicked(this.id)">
                    <label for="chkTraining">Training</label>
                    <input type="checkbox" id="chkBeginner" onclick="RankCheckboxClicked(this.id)">
                    <label for="chkBeginner">Beginner</label>
                    <input type="checkbox" id="chkPublic" onclick="RankCheckboxClicked(this.id)">
                    <label for="chkPublic">Public</label>
                    <input type="checkbox" id="chkExpert" onclick="RankCheckboxClicked(this.id)">
                    <label for="chkExpert">Expert</label>
                    <input type="checkbox" id="chkClan" onclick="RankCheckboxClicked(this.id)">
                    <label for="chkClan">Clan</label>
                </div>
            </div>
            <div id="selectMaps" style="width: 35%; display: inline-block;">
                <div class="header" style="margin: 0;">Map</div>
                <div class="list-content">
                    <input type="checkbox" id="chkRandomMap" onclick="MapCheckboxClicked(this.id)">
                    <label for="chkRandomMap">Random Map</label>
                    <input type="checkbox" id="chkGlassLab" onclick="MapCheckboxClicked(this.id)">
                    <label for="chkGlassLab">Glass Lab</label>
                    <input type="checkbox" id="chkGlassUpdown" onclick="MapCheckboxClicked(this.id)">
                    <label for="chkGlassUpdown">Glass Updown</label>
                </div>
            </div>
            <div style="width: 63%; display: inline-block;">
                <div class="header" style="margin: 0;">Other</div>
                <div class="list-content">
                    <input type="checkbox" id="chkExpUp">
                    <label for="chkExpUp">Exp Up</label>
                    <input type="checkbox" id="chkPointUp">
                    <label for="chkPointUp">Point Up</label>
                    <input type="checkbox" id="chkLog">
                    <label for="chkLog">Detailed Log</label>
                    <input type="checkbox" id="chkNoSpamChat">
                    <label for="chkNoSpamChat">No Spam Chat</label>
                    <input type="checkbox" id="chkExpBattlePass">
                    <label for="chkExpBattlePass">Exp Battle Pass Up</label>
                </div>
            </div>
        </div>
        <div class="list-content" style="border-width: 5px;">
            <div style="margin-top: -5px;">
                <div style="position: relative !important; display: inline-block !important; width: 160px;">
                    <div class="header" style="display: table;">Server</div>
                    <input type="text" id="txtServer" style="width: 160px !important; padding-left: 18px !important; padding-right: 18px !important; text-align: center !important; " onkeyup="ValidateServerRange(this)" onblur="ClearValidationOnBlur(this)" />
                    <button class="btn-list btn-up-number" onclick="ServerUp()">&#9650;</button>
                    <button class="btn-list btn-down-number" onclick="ServerDown()">&#9660;</button>
                </div>
                <div style="position: relative !important; display: inline-block !important; width: 160px;">
                    <div class="header" style="display: table;">Channel</div>
                    <input type="text" id="txtChannel" style="width: 160px !important; padding-left: 18px !important; padding-right: 18px !important; text-align: center !important; " onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ClearValidationOnBlur(this)" />
                    <button class="btn-list btn-up-number" onclick="ChannelUp()">&#9650;</button>
                    <button class="btn-list btn-down-number" onclick="ChannelDown()">&#9660;</button>
                </div>
                <div style="position: relative !important; display: inline-block !important; width: 160px;">
                    <div class="header" style="display: table;">Round</div>
                    <input type="text" id="txtRound" style="width: 160px !important; padding-left: 18px !important; padding-right: 18px !important; text-align: center !important; " onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ClearValidationOnBlur(this)" />
                    <button class="btn-list btn-up-number" onclick="RoundUp()">&#9650;</button>
                    <button class="btn-list btn-down-number" onclick="RoundDown()">&#9660;</button>
                </div>
                <div style="position: relative !important; display: inline-block !important; width: 160px;">
                    <div class="header" style="display: table;">Total TB</div>
                    <input type="text" id="txtTotalTB" style="width: 160px !important; padding-left: 18px !important; padding-right: 18px !important; text-align: center !important; " onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ClearValidationOnBlur(this)" />
                    <button class="btn-list btn-up-number" onclick="TotalTBUp()">&#9650;</button>
                    <button class="btn-list btn-down-number" onclick="TotalTBDown()">&#9660;</button>
                </div>
                <div style="position: relative !important; display: inline-block !important; width: 160px;">
                    <div class="header" style="display: table;">Max Match</div>
                    <input type="text" id="txtMaxMatch" style="width: 160px !important; padding-left: 18px !important; padding-right: 18px !important; text-align: center !important; " onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ClearValidationOnBlur(this)" />
                    <button class="btn-list btn-up-number" onclick="MaxMatchUp()">&#9650;</button>
                    <button class="btn-list btn-down-number" onclick="MaxMatchDown()">&#9660;</button>
                </div>
                <div>
                    <div style="display: inline-block;">
                        <div class="header" style="display: table;">Spam Chat</div>
                        <input type="text" title="Input Spam Chat (Enter to save)" id="txtSpamChat" style="display: inline-block; width: 270px;" onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ValidateFields(0,this)"/>
                    </div>
                    <div style="display: inline-block;">
                        <div class="header" style="display: table;">Room Title</div>
                        <input type="text" title="Input Room Title (Enter to save)" id="txtRoomTitle" style="display: inline-block; width: 270px;" onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ClearValidationOnBlur(this)"/>
                    </div>
                    <div style="display: inline-block;">
                        <div class="header" style="display: table;">Room Password</div>
                        <input type="text" title="Input Room Password (Enter to save)" id="txtRoomPassword" style="display: inline-block; width: 270px;" onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="ClearValidationOnBlur(this)"/>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer">
            <div style="height: 33px;"></div>
            <div style="float:left; margin-left: 10px;">
                <button title="Ctrl + S" onclick="SaveConfiguration()">Save</button>
                <button title="F1" onclick="StartExeScript()">Run Script</button>
            </div>
            <div style="float:right; margin-right: 10px;">
                <button title="Ctrl + R btn-danger" onclick="ResetForm()">Reset All</button>
                <button title="Escape/Esc btn-danger" onclick="self.close()">Discard</button>
            </div>
            <div style="width: 100%; margin: 0; margin-top: 45px; margin-bottom: -7px;">
                <a style="float: left;" class="header whatsapp" href="#" onclick="OpenLink('https://api.whatsapp.com/send?phone=6289528513371')">Whatsapp: 0895-2851-3371</a>
                <a class="header facebook" href="#" onclick="OpenLink('https://www.facebook.com/topupdisiniaja?rdid=l5sEgiU3Eb6Gkn1O&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F14eRyBmzCTC%2F#')">Facebook: Abdullah Khareem</a>
                <a style="float: right;" class="header instagram" href="#" onclick="OpenLink('https://www.instagram.com/topup_disini_aja')">Instagram: topup_disini_aja</a>
            </div>
        </div>
    </div>
    <div class="container" id="informationContent" style="display:none;">
        <h3>Information</h3>
        <div id="informationPanel" style="height: 398px; padding: 5px;">
            <!-- 1. Data File & Log File -->
            <div class="list-content">
                <div class="header" style="margin: 0;">1. Data File & Log File</div>
                <div class="info-text">
                    <strong>Data File</strong> : Berisi daftar akun dengan format <code class="info-text-highlight">ID Password</code> (pisahkan dengan spasi atau tab).<br>
                    <strong>Log File</strong> : Tempat menyimpan hasil proses. Format baris: <code class="info-text-highlight">Status: ID Password (Jam Tanggal)</code>, dengan header <code class="info-text-highlight">Hari, Tanggal | Waktu Mulai | Akun processed/total</code>.
                </div>
            </div>

            <!-- 2. Select Modes (hanya 1) -->
            <div class="list-content">
                <div class="header" style="margin: 0;">2. Select Modes (pilih salah satu)</div>
                <table class="info-text info-text-list">
                    <tr>
                        <td class="info-text-left"><b>Tb 2 ~ 8</b></td>
                        <td class="info-text-right">: Screenshot mode <code class="info-text-highlight">Tb</code> untuk jumlah pemain 2 s.d. 8.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Job 2 ~ 8</b></td>
                        <td class="info-text-right">: Screenshot mode <code class="info-text-highlight">Job</code> untuk jumlah pemain 2 s.d. 8.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Tb Room Master</b></td>
                        <td class="info-text-right">: Screenshot mode <code class="info-text-highlight">Tb</code> dengan posisi <code class="info-text-highlight">Room Master</code>.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Job Room Master</b></td>
                        <td class="info-text-right">: Screenshot mode <code class="info-text-highlight">Job</code> dengan posisi <code class="info-text-highlight">Room Master</code>.</td>
                    </tr>
                </table>
                <div class="info-text" style="margin-top:6px; color:#ffbb33;">⚠️ Hanya boleh memilih <b>satu</b> mode.</div>
            </div>

            <!-- 3. Rank Server (boleh lebih dari 1) -->
            <div class="list-content">
                <div class="header" style="margin: 0;">3. Rank Server (boleh pilih lebih dari satu)</div>
                <table class="info-text info-text-list">
                    <tr>
                        <td class="info-text-left"><b>Training</b></td>
                        <td class="info-text-right">: Server latihan (Training).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Beginner</b></td>
                        <td class="info-text-right">: Server pemula (Beginner).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Public</b></td>
                        <td class="info-text-right">: Server publik (Public).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Expert</b></td>
                        <td class="info-text-right">: Server ahli (Expert).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Clan</b></td>
                        <td class="info-text-right">: Server clan (Clan).</td>
                    </tr>
                </table>
                <div class="info-text" style="margin-top:6px;">Pilih satu atau lebih sesuai kebutuhan.</div>
            </div>

            <!-- 4. Other (tambahan) -->
            <div class="list-content">
                <div class="header" style="margin: 0;">4. Other (opsional tambahan)</div>
                <table class="info-text info-text-list">
                    <tr>
                        <td class="info-text-left"><b>Exp Up</b></td>
                        <td class="info-text-right">: Mengaktifkan fitur <code class="info-text-highlight">Exp Up</code> (biasanya untuk event).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Point Up</b></td>
                        <td class="info-text-right">: Mengaktifkan fitur <code class="info-text-highlight">Point Up</code>.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Detailed Log</b></td>
                        <td class="info-text-right">: Menuliskan log yang <code class="info-text-highlight">lebih detail</code> per akun.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>No Spam Chat</b></td>
                        <td class="info-text-right">: Menonaktifkan pengiriman <code class="info-text-highlight">spam chat</code> (watermark) di macro.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Exp Battle Pass Up</b></td>
                        <td class="info-text-right">: Mengaktifkan fitur <code class="info-text-highlight">Exp Battle Pass Up</code>.</td>
                    </tr>
                </table>
            </div>

            <!-- 5. Input Fields (Server, Channel, Match, Spam Chat, Room Title, Password) -->
            <div class="list-content">
                <div class="header" style="margin: 0;">5. Input Fields</div>
                <table class="info-text info-text-list">
                    <tr>
                        <td class="info-text-left"><b>Server</b></td>
                        <td class="info-text-right">: Angka <code class="info-text-highlight">3 digit</code> (1–008). Tidak boleh kosong atau 0.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Channel</b></td>
                        <td class="info-text-right">: Angka <code class="info-text-highlight">3 digit</code> (1–010). Tidak boleh kosong atau 0.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Match</b></td>
                        <td class="info-text-right">: Angka <code class="info-text-highlight">4 digit</code> (1–1000). Tidak boleh kosong atau 0.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Spam Chat</b></td>
                        <td class="info-text-right">: Teks <code class="info-text-highlight">opsional</code> (3–120 karakter). Kosongkan jika tidak digunakan.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Room Title</b></td>
                        <td class="info-text-right">: Judul ruangan <code class="info-text-highlight">opsional</code> (1–20 karakter).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Room Password</b></td>
                        <td class="info-text-right">: Password ruangan <code class="info-text-highlight">opsional</code> (1–4 karakter).</td>
                    </tr>
                </table>
                <div class="info-text" style="margin-top:6px;">Untuk Server, Channel, dan Match, gunakan tombol ▲/▼ atau ketik manual (akan otomatis diformat).</div>
            </div>

            <!-- 6. Shortcut & Tombol -->
            <div class="list-content">
                <div class="header" style="margin: 0;">6. Shortcut & Tombol</div>
                <table class="info-text info-text-list">
                    <tr>
                        <td class="info-text-left"><b>Ctrl + S</b></td>
                        <td class="info-text-right">: Simpan konfigurasi.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>F1</b></td>
                        <td class="info-text-right">: Jalankan script.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Ctrl + R</b></td>
                        <td class="info-text-right">: Reset semua pengaturan.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Escape</b></td>
                        <td class="info-text-right">: Tutup / Discard (keluar dari panel info jika terbuka).</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Ctrl + I</b></td>
                        <td class="info-text-right">: Buka / tutup panel informasi.</td>
                    </tr>
                    <tr>
                        <td class="info-text-left"><b>Ctrl + F, lalu D</b></td>
                        <td class="info-text-r8ht">: Buka dialog <code class="info-text-highlight">Browse</code> untuk memilih file Data.</td>
                    </tr>
                    <tr style="margin-left: -6px;">
                        <td class="info-text-left"><b>Ctrl + F, lalu L</b></td>
                        <td class="info-text-right">: Buka dialog <code class="info-text-highlight">Browse</code> untuk memilih file Log.</td>
                    </tr>
                </table>
                <div class="info-text" style="margin-top:6px;">Tombol <b>Save</b>, <b>Run Script</b>, <b>Reset All</b>, dan <b>Discard</b> tersedia di bagian bawah utama.</div>
            </div>

            <!-- 7. Catatan tambahan -->
            <div class="list-content">
                <div class="header" style="margin: 0;">7. Catatan</div>
                <div class="info-text">
                    • Pastikan file Data dan Log memiliki ekstensi <code class="info-text-highlight">.txt</code> atau <code class="info-text-highlight">.log</code>.<br>
                    • Server, Channel, dan Match <b>wajib diisi</b> dan tidak boleh 000 / 0000.<br>
                    • Mode hanya boleh dipilih <b>satu</b>, sedangkan Rank Server boleh lebih dari satu.<br>
                    • Fitur <b>No Spam Chat</b> akan menonaktifkan pengiriman pesan watermark di dalam game.<br>
                    • Semua input teks (kecuali angka) mendukung karakter huruf, angka, spasi, dan simbol tertentu.
                </div>
            </div>
        </div>
        <div class="footer">
            <div style="height: 33px;"></div>
            <div style="float:left; margin-left: 10px;">
                <button title="F1" onclick="StartExeScript()">Run Script</button>
            </div>
            <div style="float:right; margin-right: 10px;">
                <button title="Escape/Esc btn-danger" onclick="HideInformation()">Back</button>
            </div>
            <div style="width: 100%; margin: 0; margin-top: 45px; margin-bottom: -7px;">
                <a style="float: left;" class="header whatsapp" href="#" onclick="OpenLink('https://api.whatsapp.com/send?phone=6289528513371')">Whatsapp: 0895-2851-3371</a>
                <a class="header facebook" href="#" onclick="OpenLink('https://www.facebook.com/topupdisiniaja?rdid=l5sEgiU3Eb6Gkn1O&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F14eRyBmzCTC%2F#')">Facebook: Abdullah Khareem</a>
                <a style="float: right;" class="header instagram" href="#" onclick="OpenLink('https://www.instagram.com/topup_disini_aja')">Instagram: topup_disini_aja</a>
            </div>
        </div>
    </div>
    <div id="informationButton" style="right: 35px;" onclick="ShowInformation()">i</div>
    <div id="informationButton" style="left: 35px;" onclick="ShowInformation()">i</div>
    <div id="feedbackMsg"></div>
    <script language="javascript">
        var waitingBrowseKey = false;
        var browseTimer = null;
        var browseCountdown = null;
        var browseSeconds = 5;

        function OpenLink(url) {
            try {
                var shell=new ActiveXObject("WScript.Shell");
                shell.Run(url);
            } catch(e) {
                ShowMessage(e, "");
            }
        }

        function CenterFeedback() {
            var obj = document.getElementById("feedbackMsg");
            obj.style.left = ((document.documentElement.clientWidth - obj.offsetWidth) / 2) + "px";
        }

        window.onload = function () {
            window.resizeTo(900, 650);
            var x = (screen.width - 900) / 2;
            var y = (screen.height - 650) / 2;
            window.moveTo(x, y);
            document.body.focus();
            LoadSettings();
            
            document.attachEvent("onmousewheel", function () {
                var distance = window.event.wheelDelta / 2;
                if (document.getElementById("informationContent").style.display == "block") {
                    document.getElementById("informationPanel").scrollTop -= distance;
                }

                document.getElementById("mainPanel").scrollTop -= distance;
            });
        }
            
        document.onkeydown = function () {
            var key = window.event.keyCode;
            var ctrl = window.event.ctrlKey;

            var f1 = (key == 112)
            var esc = (key == 27)
            var enter = (key == 13)
            var keyup = (key == 38)
            var keydown = (key == 40)
            var keyleft = (key == 37)
            var keyright = (key == 39)

            var src = window.event.srcElement.id;
            var keyName = String.fromCharCode(key).toLowerCase();
            var isMainVisible = document.getElementById("mainContent").style.display == "block";
            var isInfoViewVisible = document.getElementById("informationContent").style.display == "block";

            if (ctrl && keyName == "s") {
                window.event.returnValue = false;
                if (isMainVisible) {
                    SaveConfiguration();
                }

                return false;
            }

            if (keyup || keyright) {
                window.event.returnValue = false;
                if (document.activeElement == document.getElementById("txtServer")) {
                    ServerUp();
                }

                if (document.activeElement == document.getElementById("txtChannel")) {
                    ChannelUp();
                }

                if (document.activeElement == document.getElementById("txtMaxMatch")) {
                    MaxMatchUp();
                }
                
                if (document.activeElement == document.getElementById("txtTotalTB")) {
                    TotalTBUp();
                }
                
                if (document.activeElement == document.getElementById("txtRound")) {
                    RoundUp();
                }
                return false;
            }

            if (keydown || keyleft) {
                window.event.returnValue = false;
                if (document.activeElement == document.getElementById("txtServer")) {
                    ServerDown();
                }

                if (document.activeElement == document.getElementById("txtChannel")) {
                    ChannelDown();
                }

                if (document.activeElement == document.getElementById("txtMaxMatch")) {
                    MaxMatchDown();
                }
                
                if (document.activeElement == document.getElementById("txtTotalTB")) {
                    TotalTBDown();
                }
                
                if (document.activeElement == document.getElementById("txtRound")) {
                    RoundDown();
                }
                return false;
            }

            if (f1) {
                window.event.returnValue = false;
                StartExeScript();
                return false;
            }

            if (esc) {
                window.event.returnValue = false;
                if (isInfoViewVisible) {
                    HideInformation();
                    return false;
                }

                self.close();
                return false;
            }

            if (ctrl && keyName == "r") {
                window.event.returnValue = false;
                if (isMainVisible) {
                    ResetForm();
                }
                return false;
            }

            if (ctrl && keyName == "i") {
                window.event.returnValue = false;
                if (!isInfoViewVisible) {
                    ShowInformation();
                }
                return false;
            }

            if (ctrl && keyName == "f") {
                if (isMainVisible) {
                    waitingBrowseKey = true;
                    browseSeconds = 5;
                    clearTimeout(browseTimer);
                    clearInterval(browseCountdown);
                    ShowMessage("Waiting " + browseSeconds.toFixed(1) + "s... (Press \"D\"/\"L\" button)", "msg-warning");
                    browseCountdown = setInterval(function () {
                        browseSeconds -= 0.1;
                        if (browseSeconds > 0) {
                            ShowMessage("Waiting " + browseSeconds.toFixed(1) + "s... (Press \"D\"/\"L\" button)", "msg-warning");
                        }
                    }, 100);
                    browseTimer = setTimeout(function () {
                        waitingBrowseKey = false;
                        clearInterval(browseCountdown);
                        ShowMessage("Cancelled...", "msg-error");
                        setTimeout(function () {
                            ShowMessage("", "");
                        }, 3000);
                    }, 5000);
                    return false;
                }
            }

            if (waitingBrowseKey) {
                waitingBrowseKey = false;
                clearTimeout(browseTimer);
                clearInterval(browseCountdown);
                if (keyName == "d") {
                    ShowMessage("Please browse \"Data\" path", "");
                    setTimeout(function () {
                        ShowMessage("", "");
                    }, 3000);
                    document.getElementById('fileData').click();
                }
                if (keyName == "l") {
                    ShowMessage("Please browse \"Log\" path", "");
                    setTimeout(function () {
                        ShowMessage("", "");
                    }, 3000);
                    document.getElementById('fileLog').click();
                }
                return false;
            }
        };
    </script>
</body>

</html>