    </div>
    <div id="informationButton" style="right: 35px;" onclick="ShowInformation()">i</div>
    <div id="informationButton" style="left: 35px;" onclick="ShowInformation()">i</div>
    <div id="feedbackMsg"></div>
    <script language="javascript">
        var waitingBrowseKey = false;
        var browseTimer = null;
        var browseCountdown = null;
        var browseSeconds = 5;

        function OpenLink(url) {
            try {
                var shell = new ActiveXObject("WScript.Shell");
                shell.Run(url);
            } catch (e) {
                ShowMessage(e, "");
            }
        }

        function CenterFeedback() {
            var obj = document.getElementById("feedbackMsg");
            obj.style.left = ((document.documentElement.clientWidth - obj.offsetWidth) / 2) + "px";
        }

        window.onload = function () {
            window.resizeTo(900, 560);
            var x = (screen.width - 900) / 2;
            var y = (screen.height - 560) / 2;
            window.moveTo(x, y);
            document.body.focus();
            LoadSettings();

            document.attachEvent("onmousewheel", function () {
                var distance = window.event.wheelDelta / 2;
                if (document.getElementById("spesificListContent").style.display == "block") {
                    document.getElementById("spesificListPanel").scrollTop -= distance;
                }

                if (document.getElementById("informationContent").style.display == "block") {
                    document.getElementById("informationPanel").scrollTop -= distance;
                }

                document.getElementById("mainPanel").scrollTop -= distance;
            });
        };

        document.onkeydown = function () {
            var alt = window.event.altKey;
            var key = window.event.keyCode;
            var ctrl = window.event.ctrlKey;

            var f1 = (key == 112);
            var esc = (key == 27);
            var enter = (key == 13);

            var src = window.event.srcElement.id;
            var keyName = String.fromCharCode(key).toLowerCase();
            var isMainVisible = document.getElementById("mainContent").style.display == "block";
            var isInfoViewVisible = document.getElementById("informationContent").style.display == "block";
            var isListViewVisible = document.getElementById("spesificListContent").style.display == "block";

            if (ctrl && keyName == "s") {
                window.event.returnValue = false;
                if (isMainVisible) {
                    SaveConfiguration();
                }
                if (isListViewVisible) {
                    SaveSpesificListChanges();
                    return false;
                }
                return false;
            }

            if (f1) {
                window.event.returnValue = false;
                StartExeScript();
                return false;
            }

            if (esc) {
                window.event.returnValue = false;
                if (isListViewVisible) {
                    DiscardSpesificListChanges();
                    return false;
                }
                if (isInfoViewVisible) {
                    HideInformation();
                    return false;
                }
                self.close();
                return false;
            }

            if (ctrl && keyName == "d") {
                window.event.returnValue = false;
                if (isListViewVisible) {
                    DeleteAllSpesifics();
                }
                return false;
            }

            if (ctrl && keyName == "r") {
                window.event.returnValue = false;
                if (isMainVisible) {
                    ResetForm();
                }
                return false;
            }

            if (ctrl && keyName == "w") {
                window.event.returnValue = false;
                if (!isListViewVisible) {
                    ShowSpesificList();
                }
                return false;
            }

            if (ctrl && keyName == "i") {
                window.event.returnValue = false;
                if (!isInfoViewVisible) {
                    ShowInformation();
                }
                return false;
            }

            // ====== Input Weapon Name ======
            if (src == "txtWeaponNamePopup") {
                if (enter) {
                    window.event.returnValue = false;
                    OnSpesificEnter("weapon");
                    return true;
                }
            }

            // ====== Input Item Name ======
            if (src == "txtItemNamePopup") {
                if (enter) {
                    window.event.returnValue = false;
                    OnSpesificEnter("item");
                    return true;
                }
            }

            // ====== Input Head Name ======
            if (src == "txtHeadNamePopup") {
                if (enter) {
                    window.event.returnValue = false;
                    OnSpesificEnter("head");
                    return true;
                }
            }

            // ====== Input Idol Name ======
            if (src == "txtIdolNamePopup") {
                if (enter) {
                    window.event.returnValue = false;
                    OnSpesificEnter("idol");
                    return true;
                }
            }

            // ====== Input Idol Wig Name ======
            if (src == "txtIdolWigNamePopup") {
                if (enter) {
                    window.event.returnValue = false;
                    OnSpesificEnter("idolwig");
                    return true;
                }
            }

            // ====== Input Reinforced Name ======
            if (src == "txtReinforcedNamePopup") {
                if (enter) {
                    window.event.returnValue = false;
                    OnSpesificEnter("reinforced");
                    return true;
                }
            }

            // ====== Ctrl+F ======
            if (ctrl && keyName == "f") {
                if (isMainVisible) {
                    waitingBrowseKey = true;
                    browseSeconds = 5;
                    clearTimeout(browseTimer);
                    clearInterval(browseCountdown);
                    ShowMessage("Waiting " + browseSeconds.toFixed(1) + "s... (Press \"D\"/\"L\" button)", "msg-warning");
                    browseCountdown = setInterval(function () {
                        browseSeconds -= 0.1;
                        if (browseSeconds > 0) {
                            ShowMessage("Waiting " + browseSeconds.toFixed(1) + "s... (Press \"D\"/\"L\" button)", "msg-warning");
                        }
                    }, 100);
                    browseTimer = setTimeout(function () {
                        waitingBrowseKey = false;
                        clearInterval(browseCountdown);
                        ShowMessage("Cancelled...", "msg-error");
                        setTimeout(function () { ShowMessage("", ""); }, 3000);
                    }, 5000);
                    return false;
                }
            }

            // ====== After Ctrl+F, wait for D or L ======
            if (waitingBrowseKey) {
                waitingBrowseKey = false;
                clearTimeout(browseTimer);
                clearInterval(browseCountdown);
                if (keyName == "d") {
                    ShowMessage("Please browse \"Data\" path", "");
                    setTimeout(function () { ShowMessage("", ""); }, 3000);
                    document.getElementById('fileData').click();
                } else if (keyName == "l") {
                    ShowMessage("Please browse \"Log\" path", "");
                    setTimeout(function () { ShowMessage("", ""); }, 3000);
                    document.getElementById('fileLog').click();
                }
                return false;
            }
        };
    </script>
</body>

</html>