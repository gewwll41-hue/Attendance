<!DOCTYPE html>
<html>

<head>
    <meta http-equiv="X-UA-Compatible" content="IE=9" />
    <meta http-equiv="Content-Type" content="text/html; charset=windows-1252" />
    <meta http-equiv="Cache-Control" content="no-cache" />
    <title>Setting Auto Buy Shop (ABS) - TDA</title>
    <HTA:APPLICATION ID="objHTA" APPLICATIONNAME="Setting Auto Buy Shop (ABS) - TDA" WINDOWSTATE="normal" SINGLEINSTANCE="yes"
        BORDER="none" SELECTION="no">
    </HTA:APPLICATION>
    <style>
        * {
            color: white;
            margin: 0;
            padding: 0;
            overflow: hidden;
            box-sizing: border-box;
            outline: none;
            border: none;
            text-align: center;
            justify-content: center;
            align-items: center;
            max-width: 1024px;
            max-height: 768px;
            font-family: 'Consolas', 'Lucida Console', 'Courier New', monospace;
        }
        
        body {
            display: flex;
            margin: 0 auto;
            background: #001e32;
            background-image: url("data:image/png;base64,") !important;
            background-position: center calc(50% + 8px);
            background-size: 170%;
        }
        
        h3 {
            padding: 5px;
            margin-bottom: 10px;
            border-radius: 25px 7px;
            background: rgba(0, 30, 50, 0.5);
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: -0.3px;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            box-shadow: inset 0 14px 18px -10px rgba(0, 213, 255, 0.45), inset 0 -14px 18px -10px rgba(0, 213, 255, 0.45), inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
        
        input[type="text"] {
            flex: 1;
            background: rgba(0, 30, 50, 0.5);
            border: 3px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            border-radius: 25px 7px;
            padding: 7px 18px;
            padding-bottom: 9px;
            font-size: 0.7rem;
            display: block;
            margin: 8px auto;
            cursor: text;
            width: 380px;
            min-height: 35px;
            box-shadow: inset 0 10px 14px -10px rgba(0, 213, 255, 0.35), inset 0 -10px 14px -10px rgba(0, 213, 255, 0.35), inset 7px 0 14px rgba(0, 213, 255, 0.28), inset -7px 0 14px rgba(0, 213, 255, 0.28);
        }
        
        input[type="text"]:hover {
            background: rgba(0, 221, 255, 0.30);
        }
        
        button {
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            background: rgba(0, 30, 50, 0.5) !important;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            padding: 10px 20px;
            border-radius: 25px 7px;
            font-weight: 600;
            font-size: 0.8rem;
            cursor: pointer;
            letter-spacing: 0.5px;
            box-shadow: inset 0 10px 14px -10px rgba(0, 213, 255, 0.35), inset 0 -10px 14px -10px rgba(0, 213, 255, 0.35), inset 7px 0 14px rgba(0, 213, 255, 0.28), inset -7px 0 14px rgba(0, 213, 255, 0.28);
        }
        
        button:hover {
            background: rgba(0, 213, 255, 0.30) !important;
            border-color: #00d5ff !important;
        }
        
        button:active {
            top: 0 !important;
            left: 0 !important;
        }

        a {
            display: inline-block;
            text-align: center;
            padding: 6px 16px;
            border-radius: 24px 7px;
            text-decoration: none;
        }
        
        .container {
            background: rgba(0, 0, 0, 0.5);
            margin: 10px auto;
            border-radius: 25px 7px;
            padding: 10px 10px 8px 10px;
            width: 98%;
            box-shadow: 0 20px 35px rgba(0, 213, 255, 0.4), 0 -20px 35px rgba(0, 213, 255, 0.4), 20px 0 35px rgba(0, 213, 255, 0.4), -20px 0 35px rgba(0, 213, 255, 0.4), 15px 15px 40px rgba(0, 213, 255, 0.19), -15px -15px 40px rgba(0, 213, 255, 0.19), 0 0 0 1px rgb(0, 213, 255);
        }
        
        #mainPanel,
        #spesificListPanel,
        #informationPanel {
            display: block;
            width: 100%;
            margin: 10px 0;
            padding: 5px;
            border-radius: 25px 7px;
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            box-shadow: inset 0 14px 18px -10px rgba(0, 213, 255, 0.45), inset 0 -14px 18px -10px rgba(0, 213, 255, 0.45), inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
        
        .header {
            display: inline-block;
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            font-size: 1rem;
            border-radius: 25px 7px;
            margin: 5px auto;
            padding: 4px 15px;
            background: rgba(0, 30, 50, 0.5);
            font-weight: 700;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            box-shadow: inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
        
        .list-content {
            display: block;
            flex-wrap: wrap;
            background: rgba(0, 30, 50, 0.5);
            border-radius: 25px 7px;
            margin: 10px auto;
            padding: 10px 2px 6px 2px;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            box-shadow: inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }

        .list-content label {
            display: inline-block;
            font-size: 0.85rem;
            font-weight: 500;
            cursor: pointer;
            background: rgba(0, 30, 50, 0.5);
            padding: 6px 12px;
            margin: 2px 4px;
            border-radius: 25px 7px;
            white-space: nowrap;
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
        }
        
        .list-content label:hover {
            background: rgba(0, 213, 255, 0.30);
        }
        
        .list-content input {
            width: 0;
            height: 0;
        }
        
        .list-content input:checked+label {
            background: rgba(0, 221, 255, 0.30);
        }
        
        .btn-danger {
            background: rgba(142, 46, 46, 0.5) !important;
            border-color: #ff4d4d !important;
            box-shadow: inset 0 10px 14px -10px rgba(255, 77, 77, 0.35), inset 0 -10px 14px -10px rgba(255, 77, 77, 0.35), inset 7px 0 14px rgba(255, 77, 77, 0.28), inset -7px 0 14px rgba(255, 77, 77, 0.28);
        }
        
        .btn-danger:hover {
            background: rgba(255, 77, 77, 0.5) !important;
            border-color: #ff4d4d !important;
        }
        
        .list-column {
            display: inline-block;
            width: 207px;
            vertical-align: top;
        }
        
        .spesific-row {
            width: 100%;
            background: rgba(0, 30, 50, 0.5);
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            border-radius: 25px 7px;
            margin-bottom: 4px;
            height: 32px;
            table-layout: fixed;
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            display: table !important;
            box-shadow: inset 0 3px 6px rgba(0, 213, 255, 0.25), inset 0 -3px 6px rgba(0, 213, 255, 0.25);
        }
        
        .empty-row {
            opacity: 0.5;
            border: 0.2px dashed;
            border-left: 3px solid #00d5ff;
            border-right: 3px solid #00d5ff;
            box-shadow: none;
        }
        
        .spesific-row:hover {
            background: rgba(0, 213, 255, 0.30) !important;
            border-color: #00d5ff !important;
        }
        
        .btn-list {
            width: 30px;
            height: 24px;
            margin: 0;
            padding: 0;
            cursor: pointer;
            display: inline-block !important;
        }

        .info-text {
            font-size: 0.75rem;
            line-height: 1.4;
            margin-bottom: 6px;
            display: block;
            padding-left: 8px;
        }

        .info-text-highlight {
            font-size: 0.8rem;
            color: #ffbb33;
        }

        .info-text-list,
        .info-text-left,
        .info-text-right {
            font-size: 0.8rem;
            padding-left: 8px;
            text-align: left;
        }

        .whatsapp {
            border-color: #25D366;
            background-color: rgba(37, 211, 102, 0.2);
            box-shadow: inset 10px 0 20px rgba(37, 211, 102, 0.35), inset -10px 0 20px rgba(37, 211, 102, 0.35);
        }

        .whatsapp:hover {
            background-color: rgba(37, 211, 102, 0.7);
            box-shadow: inset 0 10px 18px -10px rgba(37, 211, 102, 0.55), inset 0 -10px 18px -10px rgba(37, 211, 102, 0.55), inset 12px 0 22px rgba(37, 211, 102, 0.45), inset -12px 0 22px rgba(37, 211, 102, 0.45), 0 0 10px rgba(37, 211, 102, 0.35);
        }

        .facebook {
            border-color: #1877F2;
            background-color: rgba(24, 119, 242, 0.2);
            box-shadow: inset 10px 0 20px rgba(24, 119, 242, 0.35), inset -10px 0 20px rgba(24, 119, 242, 0.35);
        }

        .facebook:hover {
            background-color: rgba(24, 119, 242, 0.7);
            box-shadow: inset 0 10px 18px -10px rgba(24, 119, 242, 0.55), inset 0 -10px 18px -10px rgba(24, 119, 242, 0.55), inset 12px 0 22px rgba(24, 119, 242, 0.45), inset -12px 0 22px rgba(24, 119, 242, 0.45), 0 0 10px rgba(24, 119, 242, 0.35);
        }

        .instagram {
            border-color: #DD2A7B;
            background-color: rgba(221, 42, 123, 0.2);
            box-shadow: inset 10px 0 20px rgba(221, 42, 123, 0.35), inset -10px 0 20px rgba(221, 42, 123, 0.35);
        }

        .instagram:hover {
            background-color: rgba(221, 42, 123, 0.7);
            box-shadow: inset 0 10px 18px -10px rgba(221, 42, 123, 0.55), inset 0 -10px 18px -10px rgba(221, 42, 123, 0.55), inset 12px 0 22px rgba(221, 42, 123, 0.45), inset -12px 0 22px rgba(221, 42, 123, 0.45), 0 0 10px rgba(221, 42, 123, 0.35);
        }

        #informationButton {
            position: absolute;
            top: 26px;
            width: 36px;
            height: 34px;
            line-height: 36px;
            font-family: Georgia, Verdana, serif;
            font-style: italic;
            font-weight: bold;
            font-size: 1.5rem;
            background: rgba(0, 30, 50, 0.5);
            border-left: 2px solid #00d5ff;
            border-right: 2px solid #00d5ff;
            border-radius: 50%;
            box-shadow: inset 6px 0 12px rgba(0, 213, 255, 0.25), inset -6px 0 12px rgba(0, 213, 255, 0.25);
            cursor: pointer;
            z-index: 999;
        }

        #informationButton:hover {
            background: rgba(0, 213, 255, 0.30) !important;
            border-color: #00d5ff !important;
        }

        #feedbackMsg {
            position: absolute;
            border-left: 5px solid rgba(0, 0, 0, 0.0);
            border-right: 5px solid rgba(0, 0, 0, 0.0);
            font-family: 'Trebuchet MS', 'Segoe UI', 'Verdana', sans-serif;
            font-size: 1rem;
            border-radius: 25px 7px;
            font-weight: 800;
            clear: both;
            padding: 2px 15px;
            height: 22px;
            line-height: 18px;
            bottom: 121px;
            max-width: 91%;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .msg {
            color: #44ff44;
            font-size: 0.8rem !important;
            font-style: italic;
            border-color: #00d5ff !important;
            background: rgba(0, 30, 50, 0.5);
        }

        .msg-error {
            color: white;
            font-size: 0.8rem !important;
            font-style: normal;
            border-color: #ff4444 !important;
            background-color: rgba(255, 68, 68, 0.3);
        }
        
        .msg-warning {
            color: white;
            font-size: 0.8rem !important;
            font-style: normal;
            border-color: #ffbb33 !important;
            background-color: rgba(255, 187, 51, 0.3);
        }

        .valid-input {
            border-color: #44ff44 !important;
            background-color: rgba(68, 255, 68, 0.3) !important;
            box-shadow: inset 0 10px 14px -10px rgba(68, 255, 68, 0.35), inset 0 -10px 14px -10px rgba(68, 255, 68, 0.35), inset 7px 0 14px rgba(68, 255, 68, 0.28), inset -7px 0 14px rgba(68, 255, 68, 0.28) !important;
        }
        
        .invalid-input {
            border-color: #ff4444 !important;
            background-color: rgba(255, 68, 68, 0.3) !important;
            box-shadow: inset 0 10px 14px -10px rgba(255, 68, 68, 0.35), inset 0 -10px 14px -10px rgba(255, 68, 68, 0.35), inset 7px 0 14px rgba(0, 213, 255, 0.28), inset -7px 0 14px rgba(255, 68, 68, 0.28) !important;
        }
        
        .footer {
            width: 100%;
            height: fit-content;
            display: inline-block;
            padding: 15px;
            border-radius: 25px 7px;
            border: 5px solid #00d5ff;
            border-top-width: 1px;
            border-bottom-width: 1px;
            border-top-color: rgba(0, 213, 255, 0.3);
            border-bottom-color: rgba(0, 213, 255, 0.3);
            box-shadow: inset 0 14px 18px -10px rgba(0, 213, 255, 0.45), inset 0 -14px 18px -10px rgba(0, 213, 255, 0.45), inset 10px 0 20px rgba(0, 213, 255, 0.35), inset -10px 0 20px rgba(0, 213, 255, 0.35);
        }
    </style>
    <script language="VBScript">
        Dim fso, shell
        Dim WeaponListData, ItemListData, HeadListData, ReinforcedListData, IdolListData, IdolWigListData
        Dim TempWeaponListData, TempItemListData, TempHeadListData, TempReinforcedListData, TempIdolListData, TempIdolWigListData
        Dim isEditingSpesificList
        Set fso = CreateObject("Scripting.FileSystemObject")
        Set shell = CreateObject("WScript.Shell")
        Const REG_PATH = "HKCU\Software\TDA Application\Auto Buy Shop (ABS) - TDA\"
        WeaponListData = ""
        ItemListData = ""
        isEditingSpesificList = False
        
        Sub LoadSettings()
            On Error Resume Next
            Dim val
            val = shell.RegRead(REG_PATH & "WeaponListData")
            If Err.Number <> 0 Then
                WeaponListData = ""
                Err.Clear
            Else
                WeaponListData = val
            End If
        
            val = shell.RegRead(REG_PATH & "ItemListData")
            If Err.Number <> 0 Then
                ItemListData = ""
                Err.Clear
            Else
                ItemListData = val
            End If
        
            val = shell.RegRead(REG_PATH & "HeadListData")
            If Err.Number <> 0 Then
                HeadListData = ""
                Err.Clear
            Else
                HeadListData = val
            End If

            val = shell.RegRead(REG_PATH & "ReinforcedListData")
            If Err.Number <> 0 Then
                ReinforcedListData = ""
                Err.Clear
            Else
                ReinforcedListData = val
            End If

            val = shell.RegRead(REG_PATH & "IdolListData")
            If Err.Number <> 0 Then
                IdolListData = ""
                Err.Clear
            Else
                IdolListData = val
            End If

            val = shell.RegRead(REG_PATH & "IdolWigListData")
            If Err.Number <> 0 Then
                IdolWigListData = ""
                Err.Clear
            Else
                IdolWigListData = val
            End If
        
            val = shell.RegRead(REG_PATH & "DataFile")
            If Err.Number = 0 Then document.getElementById("txtDataFile").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "LogFile")
            If Err.Number = 0 Then document.getElementById("txtLogFile").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "RoomTitle")
            If Err.Number = 0 Then document.getElementById("txtRoomTitle").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "RoomPassword")
            If Err.Number = 0 Then document.getElementById("txtRoomPassword").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpesificNameWeapon")
            If Err.Number = 0 Then document.getElementById("txtWeaponNamePopup").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpesificNameItem")
            If Err.Number = 0 Then document.getElementById("txtItemNamePopup").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpesificNameHead")
            If Err.Number = 0 Then document.getElementById("txtHeadNamePopup").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpesificNameIdol")
            If Err.Number = 0 Then document.getElementById("txtIdolNamePopup").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpesificNameIdolWig")
            If Err.Number = 0 Then document.getElementById("txtIdolWigNamePopup").value = val Else Err.Clear
            val = shell.RegRead(REG_PATH & "SpesificNameReinforced")
            If Err.Number = 0 Then document.getElementById("txtReinforcedNamePopup").value = val Else Err.Clear
        
            Dim inputs, i, regVal
            Set inputs = document.getElementsByTagName("input")
            For i = 0 To inputs.length - 1
                If inputs(i).type = "checkbox" And inputs(i).id <> "" Then
                    regVal = shell.RegRead(REG_PATH & inputs(i).id)
                    If Err.Number = 0 Then
                        inputs(i).checked = (regVal = "True")
                    Else
                        inputs(i).checked = False
                        Err.Clear
                    End If
                End If
            Next
            Err.Clear
        End Sub
        
        Sub RefreshSpesificList()
            Dim listDiv, arrWep, arrItem, arrHead, arrIdol, arrIdolWig
            Dim i, weaponLeft, weaponRight, itemLeft, itemRight, headLeft, headRight, reinforcedLeft, reinforcedRight, idolLeft, idolRight, idolWigLeft, idolWigRight
            Dim numWeapon, numItem, numHead, numReinforced, numIdol, numIdolWig
            Dim currentWep, currentItem, currentHead, currentReinforced, currentIdol, currentIdolWig
            Dim rowWeapon, rowItem, rowHead, rowReinforced, rowIdol, rowIdolWig
            Dim dataWep, dataItem, dataHead, dataReinforced, dataIdol, dataIdolWig
            Dim weaponCount, itemCount, headCount, reinforcedCount, idolCount, idolWigCount
            Dim weaponGreen, itemGreen, headGreen, reinforcedGreen, idolGreen, idolWigGreen
            Dim weaponStyle, itemStyle, headStyle, reinforcedStyle, idolStyle, idolWigStyle
            Dim weaponText, itemText, headText, reinforcedText, idolText, idolWigText
            Dim addedWeaponHtml, addedItemHtml, addedHeadHtml, addedReinforcedHtml, addedIdolHtml, addedIdolWigHtml

            Set listDiv = document.getElementById("spesificListPanel")

            ' Ambil data sesuai mode editing
            If isEditingSpesificList Then
                dataWep       = TempWeaponListData
                dataItem      = TempItemListData
                dataHead = TempHeadListData
                dataReinforced = TempReinforcedListData
                dataIdol      = TempIdolListData
                dataIdolWig   = TempIdolWigListData
            Else
                dataWep       = WeaponListData
                dataItem      = ItemListData
                dataHead = HeadListData
                dataReinforced = ReinforcedListData
                dataIdol      = IdolListData
                dataIdolWig   = IdolWigListData
            End If

            ' Ubah string menjadi array
            If dataWep <> "" Then arrWep = Split(dataWep, ",") Else arrWep = Array()
            If dataItem <> "" Then arrItem = Split(dataItem, ",") Else arrItem = Array()
            If dataHead <> "" Then arrHead = Split(dataHead, ",") Else arrHead = Array()
            If dataReinforced <> "" Then arrReinforced = Split(dataReinforced, ",") Else arrReinforced = Array()
            If dataIdol <> "" Then arrIdol = Split(dataIdol, ",") Else arrIdol = Array()
            If dataIdolWig <> "" Then arrIdolWig = Split(dataIdolWig, ",") Else arrIdolWig = Array()

            ' Inisialisasi string penampung
            weaponLeft = "" : weaponRight = ""
            itemLeft   = "" : itemRight   = ""
            headLeft = "" : headRight = ""
            reinforcedLeft = "" : reinforcedRight = ""
            idolLeft   = "" : idolRight   = ""
            idolWigLeft = "" : idolWigRight = ""

            ' Loop 10 baris
            For i = 0 To 9
                numWeapon    = i + 1
                numItem      = i + 1
                numHead = i + 1
                numReinforced = i + 1
                numIdol      = i + 1
                numIdolWig   = i + 1

                ' --- Weapon ---
                If i <= UBound(arrWep) Then
                    currentWep = arrWep(i)
                    rowWeapon = _
                        "<table class='spesific-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='35' align='center'><button title='Delete """ & currentWep & """' class='btn-list btn-danger' onclick='vbscript:DeleteList(""weapon"", " & i & ")'>&#215;</button></td>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numWeapon & ".</td>" & _
                                "<td align='left' style='font-size:9px; font-style: italic;'>" & currentWep & "</td>" & _
                                "<td width='70' align='center'>" & _
                                    "<button title='Move down' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""weapon"", " & i & ", -1)'>&#9650;</button>" & _
                                    "<button title='Move up' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""weapon"", " & i & ", 1)'>&#9660;</button>" & _
                                "</td>" & _
                            "</tr>" & _
                        "</table>"
                Else
                    rowWeapon = _
                        "<table class='spesific-row empty-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numWeapon & ".</td>" & _
                                "<td align='left' style='font-size:11px;'>Weapon Empty ...</td>" & _
                            "</tr>" & _
                        "</table>"
                End If

                ' --- Item ---
                If i <= UBound(arrItem) Then
                    currentItem = arrItem(i)
                    rowItem = _
                        "<table class='spesific-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='35' align='center'><button title='Delete """ & currentItem & """' class='btn-list btn-danger' onclick='vbscript:DeleteList(""item"", " & i & ")'>&#215;</button></td>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numItem & ".</td>" & _
                                "<td align='left' style='font-size:9px; font-style: italic;'>" & currentItem & "</td>" & _
                                "<td width='70' align='center'>" & _
                                    "<button title='Move down' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""item"", " & i & ", -1)'>&#9650;</button>" & _
                                    "<button title='Move up' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""item"", " & i & ", 1)'>&#9660;</button>" & _
                                "</td>" & _
                            "</tr>" & _
                        "</table>"
                Else
                    rowItem = _
                        "<table class='spesific-row empty-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numItem & ".</td>" & _
                                "<td align='left' style='font-size:11px;'>Item Empty ...</td>" & _
                            "</tr>" & _
                        "</table>"
                End If

                ' --- Head ---
                If i <= UBound(arrHead) Then
                    currentHead = arrHead(i)
                    rowHead = _
                        "<table class='spesific-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='35' align='center'><button title='Delete """ & currentHead & """' class='btn-list btn-danger' onclick='vbscript:DeleteList(""head"", " & i & ")'>&#215;</button></td>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numHead & ".</td>" & _
                                "<td align='left' style='font-size:9px; font-style: italic;'>" & currentHead & "</td>" & _
                                "<td width='70' align='center'>" & _
                                    "<button title='Move down' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""head"", " & i & ", -1)'>&#9650;</button>" & _
                                    "<button title='Move up' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""head"", " & i & ", 1)'>&#9660;</button>" & _
                                "</td>" & _
                            "</tr>" & _
                        "</table>"
                Else
                    rowHead = _
                        "<table class='spesific-row empty-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numHead & ".</td>" & _
                                "<td align='left' style='font-size:11px;'>Head Empty ...</td>" & _
                            "</tr>" & _
                        "</table>"
                End If

                ' --- Reinforced ---
                If i <= UBound(arrReinforced) Then
                    currentReinforced = arrReinforced(i)
                    rowReinforced = _
                        "<table class='spesific-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='35' align='center'><button title='Delete """ & currentReinforced & """' class='btn-list btn-danger' onclick='vbscript:DeleteList(""reinforced"", " & i & ")'>&#215;</button></td>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numReinforced & ".</td>" & _
                                "<td align='left' style='font-size:9px; font-style: italic;'>" & currentReinforced & "</td>" & _
                                "<td width='70' align='center'>" & _
                                    "<button title='Move down' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""reinforced"", " & i & ", -1)'>&#9650;</button>" & _
                                    "<button title='Move up' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""reinforced"", " & i & ", 1)'>&#9660;</button>" & _
                                "</td>" & _
                            "</tr>" & _
                        "</table>"
                Else
                    rowReinforced = _
                        "<table class='spesific-row empty-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numReinforced & ".</td>" & _
                                "<td align='left' style='font-size:11px;'>Reinforced Empty ...</td>" & _
                            "</tr>" & _
                        "</table>"
                End If

                ' --- Idol (baru) ---
                If i <= UBound(arrIdol) Then
                    currentIdol = arrIdol(i)
                    rowIdol = _
                        "<table class='spesific-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='35' align='center'><button title='Delete """ & currentIdol & """' class='btn-list btn-danger' onclick='vbscript:DeleteList(""idol"", " & i & ")'>&#215;</button></td>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numIdol & ".</td>" & _
                                "<td align='left' style='font-size:9px; font-style: italic;'>" & currentIdol & "</td>" & _
                                "<td width='70' align='center'>" & _
                                    "<button title='Move down' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""idol"", " & i & ", -1)'>&#9650;</button>" & _
                                    "<button title='Move up' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""idol"", " & i & ", 1)'>&#9660;</button>" & _
                                "</td>" & _
                            "</tr>" & _
                        "</table>"
                Else
                    rowIdol = _
                        "<table class='spesific-row empty-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numIdol & ".</td>" & _
                                "<td align='left' style='font-size:11px;'>Idol Empty ...</td>" & _
                            "</tr>" & _
                        "</table>"
                End If

                ' --- Idol Wig (baru) ---
                If i <= UBound(arrIdolWig) Then
                    currentIdolWig = arrIdolWig(i)
                    rowIdolWig = _
                        "<table class='spesific-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='35' align='center'><button title='Delete """ & currentIdolWig & """' class='btn-list btn-danger' onclick='vbscript:DeleteList(""idolwig"", " & i & ")'>&#215;</button></td>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numIdolWig & ".</td>" & _
                                "<td align='left' style='font-size:9px; font-style: italic;'>" & currentIdolWig & "</td>" & _
                                "<td width='70' align='center'>" & _
                                    "<button title='Move down' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""idolwig"", " & i & ", -1)'>&#9650;</button>" & _
                                    "<button title='Move up' class='btn-list' style='font-size: 10px;' onclick='vbscript:MoveList(""idolwig"", " & i & ", 1)'>&#9660;</button>" & _
                                "</td>" & _
                            "</tr>" & _
                        "</table>"
                Else
                    rowIdolWig = _
                        "<table class='spesific-row empty-row' border='0' cellspacing='0' cellpadding='0'>" & _
                            "<tr>" & _
                                "<td width='20' align='left' style='font-size:9px;'>" & numIdolWig & ".</td>" & _
                                "<td align='left' style='font-size:11px;'>Idol Wig Empty ...</td>" & _
                            "</tr>" & _
                        "</table>"
                End If

                ' Pisahkan ke kolom kiri (0-5) dan kanan (6-10)
                If i < 5 Then
                    weaponLeft    = weaponLeft & rowWeapon
                    itemLeft      = itemLeft & rowItem
                    headLeft = headLeft & rowHead
                    reinforcedLeft = reinforcedLeft & rowReinforced
                    idolLeft      = idolLeft & rowIdol
                    idolWigLeft   = idolWigLeft & rowIdolWig
                Else
                    weaponRight    = weaponRight & rowWeapon
                    itemRight      = itemRight & rowItem
                    headRight = headRight & rowHead
                    reinforcedRight = reinforcedRight & rowReinforced
                    idolRight      = idolRight & rowIdol
                    idolWigRight   = idolWigRight & rowIdolWig
                End If
            Next

            ' --- Hitung jumlah dan tentukan warna ---
            weaponCount    = UBound(arrWep) + 1
            itemCount      = UBound(arrItem) + 1
            headCount = UBound(arrHead) + 1
            reinforcedCount = UBound(arrReinforced) + 1
            idolCount      = UBound(arrIdol) + 1
            idolWigCount   = UBound(arrIdolWig) + 1

            weaponText    = weaponCount & " of 10 Weapons Filled"
            itemText      = itemCount & " of 10 Items Filled"
            headText = headCount & " of 10 Heads Filled"
            reinforcedText = reinforcedCount & " of 10 Reinforced Filled"
            idolText      = idolCount & " of 10 Idols Filled"
            idolWigText   = idolWigCount & " of 10 Idol Wigs Filled"

            If weaponCount = 0 Then weaponText = "No weapons added"
            If itemCount = 0 Then itemText = "No items added"
            If headCount = 0 Then headText = "No heads added"
            If reinforcedCount = 0 Then reinforcedText = "No reinforced added"
            If idolCount = 0 Then idolText = "No idols added"
            If idolWigCount = 0 Then idolWigText = "No idol wigs added"

            ' Warna default abu-abu
            weaponStyle    = "color: rgba(160, 160, 160, 1);"
            itemStyle      = "color: rgba(160, 160, 160, 1);"
            headStyle = "color: rgba(160, 160, 160, 1);"
            reinforcedStyle = "color: rgba(160, 160, 160, 1);"
            idolStyle      = "color: rgba(160, 160, 160, 1);"
            idolWigStyle   = "color: rgba(160, 160, 160, 1);"

            ' Atur warna hijau sesuai jumlah (semakin banyak semakin merah)
            If weaponCount > 0 Then
                weaponGreen = 255 - (weaponCount * 9)
                If weaponGreen < 60 Then weaponGreen = 60
                weaponStyle = "color: rgba(255, " & weaponGreen & ", 40, 1);"
            End If
            If itemCount > 0 Then
                itemGreen = 255 - (itemCount * 9)
                If itemGreen < 60 Then itemGreen = 60
                itemStyle = "color: rgba(255, " & itemGreen & ", 40, 1);"
            End If
            If headCount > 0 Then
                headGreen = 255 - (headCount * 9)
                If headGreen < 60 Then headGreen = 60
                headStyle = "color: rgba(255, " & headGreen & ", 40, 1);"
            End If
            If reinforcedCount > 0 Then
                reinforcedGreen = 255 - (reinforcedCount * 9)
                If reinforcedGreen < 60 Then reinforcedGreen = 60
                reinforcedStyle = "color: rgba(255, " & reinforcedGreen & ", 40, 1);"
            End If
            If idolCount > 0 Then
                idolGreen = 255 - (idolCount * 9)
                If idolGreen < 60 Then idolGreen = 60
                idolStyle = "color: rgba(255, " & idolGreen & ", 40, 1);"
            End If
            If idolWigCount > 0 Then
                idolWigGreen = 255 - (idolWigCount * 9)
                If idolWigGreen < 60 Then idolWigGreen = 60
                idolWigStyle = "color: rgba(255, " & idolWigGreen & ", 40, 1);"
            End If

            ' Tampilkan pesan "Max reached" jika penuh
            If weaponCount >= 10 Then
                weaponStyle = "color: rgba(255, 70, 70, 1);"
                weaponText = "Max weapon reached"
            End If
            If itemCount >= 10 Then
                itemStyle = "color: rgba(255, 70, 70, 1);"
                itemText = "Max item reached"
            End If
            If headCount >= 10 Then
                headStyle = "color: rgba(255, 70, 70, 1);"
                headText = "Max head reached"
            End If
            If reinforcedCount >= 10 Then
                reinforcedStyle = "color: rgba(255, 70, 70, 1);"
                reinforcedText = "Max reinforced reached"
            End If
            If idolCount >= 10 Then
                idolStyle = "color: rgba(255, 70, 70, 1);"
                idolText = "Max idol reached"
            End If
            If idolWigCount >= 10 Then
                idolWigStyle = "color: rgba(255, 70, 70, 1);"
                idolWigText = "Max idol wig reached"
            End If

            ' Buat HTML info tambahan di bawah header
            addedWeaponHtml    = "<div style='display: block; margin-top: 6px; padding-top: 4px; border-top: 1px solid rgb(160, 160, 160); font-size: 0.7rem; " & weaponStyle & "'>" & weaponText & "</div>"
            addedItemHtml      = "<div style='display: block; margin-top: 6px; padding-top: 4px; border-top: 1px solid rgb(160, 160, 160); font-size: 0.7rem; " & itemStyle & "'>" & itemText & "</div>"
            addedHeadHtml = "<div style='display: block; margin-top: 6px; padding-top: 4px; border-top: 1px solid rgb(160, 160, 160); font-size: 0.7rem; " & headStyle & "'>" & headText & "</div>"
            addedReinforcedHtml = "<div style='display: block; margin-top: 6px; padding-top: 4px; border-top: 1px solid rgb(160, 160, 160); font-size: 0.7rem; " & reinforcedStyle & "'>" & reinforcedText & "</div>"
            addedIdolHtml      = "<div style='display: block; margin-top: 6px; padding-top: 4px; border-top: 1px solid rgb(160, 160, 160); font-size: 0.7rem; " & idolStyle & "'>" & idolText & "</div>"
            addedIdolWigHtml   = "<div style='display: block; margin-top: 6px; padding-top: 4px; border-top: 1px solid rgb(160, 160, 160); font-size: 0.7rem; " & idolWigStyle & "'>" & idolWigText & "</div>"

            ' Tampilkan semua daftar dalam panel
            listDiv.innerHTML = _
                "<div style='display: inline-block;'>" & _
                    "<!-- Weapon -->" & _
                    "<div style='display: inline-block;'>" & _
                        "<div class='header' style='display: table;'>Weapon list" & addedWeaponHtml & "</div>" & _
                        "<div class='list-column' style='margin-right: 4px;'>" & weaponLeft & "</div>" & _
                        "<div class='list-column'>" & weaponRight & "</div>" & _
                    "</div>" & _
                    "<!-- Head -->" & _
                    "<div style='display: inline-block;'>" & _
                        "<div class='header' style='display: table;'>Head list" & addedHeadHtml & "</div>" & _
                        "<div class='list-column' style='margin-right: 4px;'>" & headLeft & "</div>" & _
                        "<div class='list-column'>" & headRight & "</div>" & _
                    "</div>" & _
                    "<!-- Reinforced -->" & _
                    "<div style='display: inline-block;'>" & _
                        "<div class='header' style='display: table;'>Reinforced list" & addedReinforcedHtml & "</div>" & _
                        "<div class='list-column' style='margin-right: 4px;'>" & reinforcedLeft & "</div>" & _
                        "<div class='list-column'>" & reinforcedRight & "</div>" & _
                    "</div>" & _
                    "<!-- Item -->" & _
                    "<div style='display: inline-block;'>" & _
                        "<div class='header' style='display: table;'>Item list" & addedItemHtml & "</div>" & _
                        "<div class='list-column' style='margin-right: 4px;'>" & itemLeft & "</div>" & _
                        "<div class='list-column'>" & itemRight & "</div>" & _
                    "</div>" & _
                    "<!-- Idol (baru) -->" & _
                    "<div style='display: inline-block;'>" & _
                        "<div class='header' style='display: table;'>Idol list" & addedIdolHtml & "</div>" & _
                        "<div class='list-column' style='margin-right: 4px;'>" & idolLeft & "</div>" & _
                        "<div class='list-column'>" & idolRight & "</div>" & _
                    "</div>" & _
                    "<!-- Idol Wig (baru) -->" & _
                    "<div style='display: inline-block;'>" & _
                        "<div class='header' style='display: table;'>Idol Wig list" & addedIdolWigHtml & "</div>" & _
                        "<div class='list-column' style='margin-right: 4px;'>" & idolWigLeft & "</div>" & _
                        "<div class='list-column'>" & idolWigRight & "</div>" & _
                    "</div>" & _
                "</div>"
            ' Paksa scroll agar bisa digerakkan
            listDiv.scrollTop = 1
            listDiv.style.display = "none"
            listDiv.style.display = "block"
            ' Set scroll ke atas lagi
            listDiv.scrollTop = 0
        End Sub

        Sub OnSpesificEnter(typ)
            Dim inputObj, newValue, currentList, arrData, totalItem, newList
            Dim j2, ch2, allowedChars, hasInvalid

            ' Ambil elemen input yang aktif
            Set inputObj = document.getElementById(document.activeElement.id)
            newValue = Trim(inputObj.value)

            If newValue = "" Then Exit Sub

            ' Karakter yang diizinkan (sama untuk semua)
            allowedChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789 -()."

            ' Validasi karakter
            hasInvalid = False
            For j2 = 1 To Len(newValue)
                ch2 = Mid(newValue, j2, 1)
                If InStr(1, allowedChars, ch2, 1) = 0 Then
                    hasInvalid = True
                    Exit For
                End If
            Next
            
            If hasInvalid Then
                ShowMessage "Karakter tidak diizinkan (hanya huruf, angka, spasi, -, (, ), .)", "msg-warning"
                Exit Sub
            End If

            ' Validasi panjang
            If Len(newValue) < 3 Then
                ShowMessage "Too short (" & Len(newValue) & " char, min 3)", "msg-error"
                Exit Sub
            End If
            If Len(newValue) > 25 Then
                ShowMessage "Too long (" & Len(newValue) & " char, max 25)", "msg-error"
                Exit Sub
            End If

            ' Pilih list berdasarkan tipe
            If typ = "weapon" Then
                If isEditingSpesificList Then currentList = TempWeaponListData Else currentList = WeaponListData
            ElseIf typ = "item" Then
                If isEditingSpesificList Then currentList = TempItemListData Else currentList = ItemListData
            ElseIf typ = "head" Then
                If isEditingSpesificList Then currentList = TempHeadListData Else currentList = HeadListData
            ElseIf typ = "reinforced" Then
                If isEditingSpesificList Then currentList = TempReinforcedListData Else currentList = ReinforcedListData
            ElseIf typ = "idol" Then
                If isEditingSpesificList Then currentList = TempIdolListData Else currentList = IdolListData
            ElseIf typ = "idolwig" Then
                If isEditingSpesificList Then currentList = TempIdolWigListData Else currentList = IdolWigListData
            Else
                Exit Sub
            End If

            ' Cek duplikat
            If currentList <> "" Then
                If InStr(1, "," & currentList & ",", "," & newValue & ",", 1) > 0 Then
                    ShowMessage "Duplicate: " & newValue, "msg-warning"
                    Exit Sub
                End If
            End If

            ' Cek batas maksimal 10
            If currentList <> "" Then
                arrData = Split(currentList, ",")
                If UBound(arrData) >= 9 Then
                    ShowMessage "Max 10 reached for " & typ, "msg-warning"
                    Exit Sub
                End If
            End If

            ' Tambahkan ke list
            If currentList = "" Then
                newList = newValue
                totalItem = 1
            Else
                newList = currentList & "," & newValue
                arrData = Split(newList, ",")
                totalItem = UBound(arrData) + 1
            End If

            ' Simpan ke variabel yang sesuai
            If typ = "weapon" Then
                If isEditingSpesificList Then TempWeaponListData = newList Else WeaponListData = newList
                ShowMessage "Added weapon: " & newValue & " (" & totalItem & "/10)", ""
            ElseIf typ = "item" Then
                If isEditingSpesificList Then TempItemListData = newList Else ItemListData = newList
                ShowMessage "Added item: " & newValue & " (" & totalItem & "/10)", ""
            ElseIf typ = "head" Then
                If isEditingSpesificList Then TempHeadListData = newList Else HeadListData = newList
                ShowMessage "Added head: " & newValue & " (" & totalItem & "/10)", ""
            ElseIf typ = "reinforced" Then
                If isEditingSpesificList Then TempReinforcedListData = newList Else ReinforcedListData = newList
                ShowMessage "Added reinforced: " & newValue & " (" & totalItem & "/10)", ""
            ElseIf typ = "idol" Then
                If isEditingSpesificList Then TempIdolListData = newList Else IdolListData = newList
                ShowMessage "Added idol: " & newValue & " (" & totalItem & "/10)", ""
            ElseIf typ = "idolwig" Then
                If isEditingSpesificList Then TempIdolWigListData = newList Else IdolWigListData = newList
                ShowMessage "Added idol wig: " & newValue & " (" & totalItem & "/10)", ""
            End If

            ' Kosongkan input dan refresh tampilan
            inputObj.value = ""
            RefreshSpesificList()
        End Sub

        Sub MoveList(typ, index, direction)
            Dim arrData, temp, target, currentList
            If typ = "weapon" Then
                If isEditingSpesificList Then currentList = TempWeaponListData Else currentList = WeaponListData
            ElseIf typ = "item" Then
                If isEditingSpesificList Then currentList = TempItemListData Else currentList = ItemListData
            ElseIf typ = "head" Then
                If isEditingSpesificList Then currentList = TempHeadListData Else currentList = HeadListData
            ElseIf typ = "reinforced" Then
                If isEditingSpesificList Then currentList = TempReinforcedListData Else currentList = ReinforcedListData
            ElseIf typ = "idol" Then
                If isEditingSpesificList Then currentList = TempIdolListData Else currentList = IdolListData
            ElseIf typ = "idolwig" Then
                If isEditingSpesificList Then currentList = TempIdolWigListData Else currentList = IdolWigListData
            Else
                Exit Sub
            End If
            If currentList = "" Then Exit Sub
            arrData = Split(currentList, ",")
            target = index + direction
            If target >= 0 And target <= UBound(arrData) Then
                temp = arrData(target)
                arrData(target) = arrData(index)
                arrData(index) = temp
                If typ = "weapon" Then
                    If isEditingSpesificList Then TempWeaponListData = Join(arrData, ",") Else WeaponListData = Join(arrData, ",")
                ElseIf typ = "item" Then
                    If isEditingSpesificList Then TempItemListData = Join(arrData, ",") Else ItemListData = Join(arrData, ",")
                ElseIf typ = "head" Then
                    If isEditingSpesificList Then TempHeadListData = Join(arrData, ",") Else HeadListData = Join(arrData, ",")
                ElseIf typ = "reinforced" Then
                    If isEditingSpesificList Then TempReinforcedListData = Join(arrData, ",") Else ReinforcedListData = Join(arrData, ",")
                ElseIf typ = "idol" Then
                    If isEditingSpesificList Then TempIdolListData = Join(arrData, ",") Else IdolListData = Join(arrData, ",")
                ElseIf typ = "idolwig" Then
                    If isEditingSpesificList Then TempIdolWigListData = Join(arrData, ",") Else IdolWigListData = Join(arrData, ",")
                End If
                RefreshSpesificList()
            End If
        End Sub

        Sub DeleteList(typ, index)
            Dim arrData, i, newList, currentList
            If typ = "weapon" Then
                If isEditingSpesificList Then currentList = TempWeaponListData Else currentList = WeaponListData
            ElseIf typ = "item" Then
                If isEditingSpesificList Then currentList = TempItemListData Else currentList = ItemListData
            ElseIf typ = "head" Then
                If isEditingSpesificList Then currentList = TempHeadListData Else currentList = HeadListData
            ElseIf typ = "reinforced" Then
                If isEditingSpesificList Then currentList = TempReinforcedListData Else currentList = ReinforcedListData
            ElseIf typ = "idol" Then
                If isEditingSpesificList Then currentList = TempIdolListData Else currentList = IdolListData
            ElseIf typ = "idolwig" Then
                If isEditingSpesificList Then currentList = TempIdolWigListData Else currentList = IdolWigListData
            Else
                Exit Sub
            End If
            If currentList = "" Then Exit Sub
            arrData = Split(currentList, ",")
            newList = ""
            For i = 0 To UBound(arrData)
                If i <> index Then
                    If newList = "" Then newList = arrData(i) Else newList = newList & "," & arrData(i)
                End If
            Next
            If typ = "weapon" Then
                If isEditingSpesificList Then TempWeaponListData = newList Else WeaponListData = newList
            ElseIf typ = "item" Then
                If isEditingSpesificList Then TempItemListData = newList Else ItemListData = newList
            ElseIf typ = "head" Then
                If isEditingSpesificList Then TempHeadListData = newList Else HeadListData = newList
            ElseIf typ = "reinforced" Then
                If isEditingSpesificList Then TempReinforcedListData = newList Else ReinforcedListData = newList
            ElseIf typ = "idol" Then
                If isEditingSpesificList Then TempIdolListData = newList Else IdolListData = newList
            ElseIf typ = "idolwig" Then
                If isEditingSpesificList Then TempIdolWigListData = newList Else IdolWigListData = newList
            End If
            RefreshSpesificList()
            ShowMessage "", ""
        End Sub
        
        Sub DeleteAllSpesifics()
            document.getElementById("txtWeaponNamePopup").value = ""
            document.getElementById("txtItemNamePopup").value = ""
            document.getElementById("txtHeadNamePopup").value = ""
            document.getElementById("txtIdolNamePopup").value = ""
            document.getElementById("txtIdolWigNamePopup").value = ""
            document.getElementById("txtReinforcedNamePopup").value = ""
            If isEditingSpesificList Then
                TempWeaponListData = ""
                TempItemListData = ""
                TempHeadListData = ""
                TempIdolListData = ""
                TempIdolWigListData = ""
                TempReinforcedListData = ""
            Else
                WeaponListData = ""
                ItemListData = ""
                HeadListData = ""
                IdolListData = ""
                IdolWigListData = ""
                ReinforcedListData = ""
            End If
            RefreshSpesificList()
            ShowMessage "All items deleted", ""
        End Sub
        
        Sub SaveSpesificListChanges()
            document.body.Focus
            WeaponListData = TempWeaponListData
            ItemListData = TempItemListData
            HeadListData = TempHeadListData
            IdolListData = TempIdolListData
            IdolWigListData = TempIdolWigListData
            ReinforcedListData = TempReinforcedListData
            SaveSettings
            isEditingSpesificList = False
            ShowMessage "Spesific list saved", ""
        End Sub
        
        Sub DiscardSpesificListChanges()
            isEditingSpesificList = False
            HideSpesificList()
        End Sub
        
        Sub ResetForm()
            If IsAllInputEmpty() Then
                ShowMessage "", ""
                Exit Sub
            End If
            document.getElementById("txtDataFile").value = ""
            document.getElementById("txtLogFile").value = ""
            document.getElementById("txtRoomTitle").value = ""
            document.getElementById("txtRoomPassword").value = ""
            document.getElementById("txtWeaponNamePopup").value = ""
            document.getElementById("txtItemNamePopup").value = ""
            document.getElementById("txtHeadNamePopup").value = ""
            document.getElementById("txtIdolNamePopup").value = ""
            document.getElementById("txtIdolWigNamePopup").value = ""
            document.getElementById("txtReinforcedNamePopup").value = ""
            WeaponListData = ""
            ItemListData = ""
            HeadListData = ""
            TempWeaponListData = ""
            TempItemListData = ""
            TempHeadListData = ""
            IdolListData = ""
            IdolWigListData = ""
            TempIdolListData = ""
            TempIdolWigListData = ""
            ReinforcedListData = ""
            TempReinforcedListData = ""
            isEditingSpesificList = False
            RefreshSpesificList
            Dim inputs, i
            Set inputs = document.getElementsByTagName("input")
            For i = 0 To inputs.length - 1
                If inputs(i).type = "checkbox" Then
                    inputs(i).checked = False
                End If
            Next
            ShowMessage "All configuration reseted", ""
        End Sub
        
        Sub HideSpesificList()
            document.body.style.cssText = "background-position:center calc(50% + 4px);background-size:170%;"
            
            window.resizeTo 900, 560
            Dim x, y
            x = (screen.width - 900) / 2
            y = (screen.height - 560) / 2
            window.moveTo x, y

            isEditingSpesificList = False
            document.getElementById("mainContent").style.display = "block"
            document.getElementById("spesificListContent").style.display = "none"
            document.getElementById("informationContent").style.display = "none"
            ShowMessage "", ""
        End Sub
        
        Sub ShowSpesificList()
            document.body.style.cssText = "background-position:center calc(50% + 8px);background-size:200%;"
            
            window.resizeTo 900, 650
            Dim x, y
            x = (screen.width - 900) / 2
            y = (screen.height - 650) / 2
            window.moveTo x, y
            
            isEditingSpesificList = True
            TempWeaponListData = WeaponListData
            TempItemListData = ItemListData
            TempHeadListData = HeadListData
            TempIdolListData = IdolListData
            TempIdolWigListData = IdolWigListData
            TempReinforcedListData = ReinforcedListData
            document.getElementById("mainContent").style.display = "none"
            document.getElementById("spesificListContent").style.display = "block"
            document.getElementById("informationContent").style.display = "none"
            ShowMessage "", ""
            RefreshSpesificList()
        End Sub
        
        Sub HideInformation()
            document.body.style.cssText = "background-position:center calc(50% + 4px);background-size:170%;"
            
            window.resizeTo 900, 560
            Dim x, y
            x = (screen.width - 900) / 2
            y = (screen.height - 560) / 2
            window.moveTo x, y

            document.getElementById("mainContent").style.display = "block"
            document.getElementById("spesificListContent").style.display = "none"
            document.getElementById("informationContent").style.display = "none"
            ShowMessage "", ""
        End Sub
        
        Sub ShowInformation()
            document.body.style.cssText = "background-position:center calc(50% + 8px);background-size:200%;"
            
            window.resizeTo 900, 650
            Dim x, y
            x = (screen.width - 900) / 2
            y = (screen.height - 650) / 2
            window.moveTo x, y
            
            document.getElementById("mainContent").style.display = "none"
            document.getElementById("spesificListContent").style.display = "none"
            document.getElementById("informationContent").style.display = "block"
            ShowMessage "", ""
        End Sub
        
        Function IsAllInputEmpty()
            If Trim(document.getElementById("txtDataFile").value) <> "" Then IsAllInputEmpty = False : Exit Function
            If Trim(document.getElementById("txtLogFile").value) <> "" Then IsAllInputEmpty = False : Exit Function
            If Trim(document.getElementById("txtRoomTitle").value) <> "" Then IsAllInputEmpty = False : Exit Function
            If Trim(document.getElementById("txtRoomPassword").value) <> "" Then IsAllInputEmpty = False : Exit Function
        
            Dim chk
            Set chk = document.getElementById("chkCreateRoom")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkLog")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function
            Set chk = document.getElementById("chkUsePoint")
            If chk.Checked Then IsAllInputEmpty = False : Exit Function

            If WeaponListData <> "" Then IsAllInputEmpty = False : Exit Function
        
            IsAllInputEmpty = True
        End Function
        
        Sub SetDataFile()
            Dim txtDataFileEl
            Set txtDataFileEl = document.getElementById("txtDataFile")
            txtDataFileEl.value = document.getElementById("fileData").value
            ValidateDataFile txtDataFileEl
            txtDataFileEl.className = ""
        End Sub

        Sub SetLogFile()
            Dim txtLogFileEl
            Set txtLogFileEl = document.getElementById("txtLogFile")
            txtLogFileEl.value = document.getElementById("fileLog").value
            ValidateLogFile txtLogFileEl
            txtLogFileEl.className = ""
        End Sub

        Function ValidateDataFile(targetEl)
            Dim path, fsoLocal, fileName, ext
            Dim isValid
            Set fsoLocal = CreateObject("Scripting.FileSystemObject")
            path = Trim(document.getElementById("txtDataFile").value)
            fileName = fsoLocal.GetBaseName(path)
            ext = LCase(fsoLocal.GetExtensionName(path))
            
            If Not IsEmpty(targetEl) Then targetEl.className = ""
            
            If path = "" Then
                ShowMessage "", ""
                isValid = True
            Else
                If Not fsoLocal.FileExists(path) Then
                    ShowMessage "Invalid file: " & path, "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf ext <> "txt" Then
                    ShowMessage "Please select "".txt"" file (" & fileName & """." & ext & """)", "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf Trim(document.getElementById("txtLogFile").value) <> "" And path = Trim(document.getElementById("txtLogFile").value) Then
                    ShowMessage "Log file: " & path, "msg-error"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                Else
                    ShowMessage path, ""
                    isValid = True
                    If Not IsEmpty(targetEl) Then targetEl.className = "valid-input"
                End If
            End If
            
            ValidateDataFile = isValid
        End Function

        Function ValidateLogFile(targetEl)
            Dim path, fsoLocal, fileName, ext
            Dim isValid
            Set fsoLocal = CreateObject("Scripting.FileSystemObject")
            path = Trim(document.getElementById("txtLogFile").value)
            fileName = fsoLocal.GetBaseName(path)
            ext = LCase(fsoLocal.GetExtensionName(path))
            
            If Not IsEmpty(targetEl) Then targetEl.className = ""
            
            If path = "" Then
                ShowMessage "", ""
                isValid = True
            Else
                If Not fsoLocal.FileExists(path) Then
                    ShowMessage "Invalid file: " & path, "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf ext <> "txt" And ext <> "log" Then
                    ShowMessage "Please select "".txt""/"".log"" file (" & fileName & """." & ext & """)", "msg-warning"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                ElseIf Trim(document.getElementById("txtDataFile").value) <> "" And path = Trim(document.getElementById("txtDataFile").value) Then
                    ShowMessage "Data file: " & path, "msg-error"
                    isValid = False
                    If Not IsEmpty(targetEl) Then targetEl.className = "invalid-input"
                Else
                    ShowMessage path, ""
                    isValid = True
                    If Not IsEmpty(targetEl) Then targetEl.className = "valid-input"
                End If
            End If
            
            ValidateLogFile = isValid
        End Function
        
        Function ValidateFields(mode, targetEl)
            Dim fields, i, el, val, minLen, maxLen, isOpt, fieldId, fieldName
            Dim isValid, j, ch, allowedChars, hasInvalidChar, invalidChars
            Dim isFinal
            isFinal = (mode = 1)
            
            fields = Array( _
                "txtWeaponNamePopup", "Weapon Name", 3, 25, True, _
                "txtItemNamePopup", "Item Name", 3, 25, True, _
                "txtHeadNamePopup", "Head Name", 3, 25, True, _
                "txtIdolNamePopup", "Idol Name", 3, 25, True, _
                "txtIdolWigNamePopup", "Idol Wig Name", 3, 25, True, _
                "txtReinforcedNamePopup", "Reinforced Name", 3, 25, True, _
                "txtRoomTitle", "Room Title", 1, 20 , True, _
                "txtRoomPassword", "Room Password", 1, 4,   True _
            )
            
            If isFinal Then
                For i = 0 To UBound(fields) Step 5
                    fieldId = fields(i)
                    fieldName = fields(i+1)
                    minLen = fields(i+2)
                    maxLen = fields(i+3)
                    isOpt = fields(i+4)
                    Set el = document.getElementById(fieldId)
                    val = Trim(el.value)
                    
                    If isOpt And val = "" Then
                    Else
                        If Len(val) < minLen Then
                            ShowMessage fieldName & ": Too short (" & Len(val) & " char, min " & minLen & ")", "msg-error"
                            el.focus
                            ValidateFields = False
                            Exit Function
                        ElseIf Len(val) > maxLen Then
                            ShowMessage fieldName & ": Too long (" & Len(val) & " char, max " & maxLen & ")", "msg-error"
                            el.focus
                            ValidateFields = False
                            Exit Function
                        End If
                    End If
                    
                    If Not (isOpt And val = "") Then
                        allowedChars = GetAllowedChars(fieldId)
                        If allowedChars <> "" Then
                            hasInvalidChar = False
                            invalidChars = ""
                            For j = 1 To Len(val)
                                ch = Mid(val, j, 1)
                                If InStr(1, allowedChars, ch, 1) = 0 Then
                                    hasInvalidChar = True
                                    If InStr(invalidChars, ch) = 0 Then
                                        invalidChars = invalidChars & ch
                                    End If
                                End If
                            Next
                            If hasInvalidChar Then
                                ShowMessage "Invalid head (" & fieldName & "): " & invalidChars, "msg-error"
                                el.focus
                                ValidateFields = False
                                Exit Function
                            End If
                        End If
                    End If
                Next
                ValidateFields = True
                Exit Function
            End If
            
            For i = 0 To UBound(fields) Step 5
                fieldId = fields(i)
                fieldName = fields(i+1)
                minLen = fields(i+2)
                maxLen = fields(i+3)
                isOpt = fields(i+4)
                
                Set el = document.getElementById(fieldId)
                val = Trim(el.value)
                
                If Not IsEmpty(targetEl) And fieldId = targetEl.id Then
                    If Not IsEmpty(targetEl) Then targetEl.className = ""
                    
                    If val = "" Then
                        ShowMessage "", ""
                        isValid = True
                    Else
                        If Len(val) < minLen Then
                            ShowMessage fieldName & ": Too short (" & Len(val) & " char, min " & minLen & ")", "msg-error"
                            isValid = False
                            targetEl.className = "invalid-input"
                        ElseIf Len(val) > maxLen Then
                            ShowMessage fieldName & ": Too long (" & Len(val) & " char, max " & maxLen & ")", "msg-error"
                            isValid = False
                            targetEl.className = "invalid-input"
                        Else
                            allowedChars = GetAllowedChars(fieldId)
                            If allowedChars <> "" Then
                                hasInvalidChar = False
                                invalidChars = ""
                                For j = 1 To Len(val)
                                    ch = Mid(val, j, 1)
                                    If InStr(1, allowedChars, ch, 1) = 0 Then
                                        hasInvalidChar = True
                                        If InStr(invalidChars, ch) = 0 Then
                                            invalidChars = invalidChars & ch
                                        End If
                                    End If
                                Next
                                If hasInvalidChar Then
                                    ShowMessage "Invalid head (" & fieldName & "): " & invalidChars, "msg-error"
                                    isValid = False
                                    targetEl.className = "invalid-input"
                                Else
                                    ShowMessage val, ""
                                    isValid = True
                                    targetEl.className = "valid-input"
                                End If
                            Else
                                ShowMessage val, ""
                                isValid = True
                                targetEl.className = "valid-input"
                            End If
                        End If
                    End If
                    ValidateFields = isValid
                    Exit Function
                End If
            Next
            
            ValidateFields = True
        End Function

        Function GetAllowedChars(fieldId)
            Select Case fieldId
                Case "txtWeaponNamePopup", "txtItemNamePopup", "txtHeadNamePopup", "txtIdolNamePopup", "txtIdolWigNamePopup", "txtReinforcedNamePopup"
                    GetAllowedChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789 -()."
                Case "txtRoomTitle"
                    GetAllowedChars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789 !?%&*/\@-().,_|"
                Case Else
                    GetAllowedChars = ""
            End Select
        End Function

        Sub clearValidationClass(el)
            If Not IsEmpty(el) Then
                el.className = ""
            End If
        End Sub
        
        Sub StartExeScript()
            Path = "C:\Script - TDA\GB Auto Buy Shop - TDA\Start GB Auto Buy Shop (ABS) - TDA.exe"
            If fso.FileExists(Path) Then
                SaveConfiguration()
                shell.Run Chr(34) & Path & Chr(34), 1, False
                self.close()
            End If
            ShowMessage "Script not found", "msg-error"
        End Sub
        
        Sub SaveSettings()
            On Error Resume Next
            document.body.Focus
            shell.RegWrite REG_PATH & "DataFile", document.getElementById("txtDataFile").value, "REG_SZ"
            shell.RegWrite REG_PATH & "LogFile", document.getElementById("txtLogFile").value, "REG_SZ"
            shell.RegWrite REG_PATH & "WeaponListData", WeaponListData, "REG_SZ"
            shell.RegWrite REG_PATH & "ItemListData", ItemListData, "REG_SZ"
            shell.RegWrite REG_PATH & "HeadListData", HeadListData, "REG_SZ"
            shell.RegWrite REG_PATH & "ReinforcedListData", ReinforcedListData, "REG_SZ"
            shell.RegWrite REG_PATH & "IdolListData", IdolListData, "REG_SZ"
            shell.RegWrite REG_PATH & "IdolWigListData", IdolWigListData, "REG_SZ"
            shell.RegWrite REG_PATH & "RoomTitle", document.getElementById("txtRoomTitle").value, "REG_SZ"
            shell.RegWrite REG_PATH & "RoomPassword", document.getElementById("txtRoomPassword").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpesificNameWeapon", document.getElementById("txtWeaponNamePopup").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpesificNameIdol", document.getElementById("txtIdolNamePopup").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpesificNameIdolWig", document.getElementById("txtIdolWigNamePopup").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpesificNameItem", document.getElementById("txtItemNamePopup").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpesificNameHead", document.getElementById("txtHeadNamePopup").value, "REG_SZ"
            shell.RegWrite REG_PATH & "SpesificNameReinforced", document.getElementById("txtReinforcedNamePopup").value, "REG_SZ"
        
            Dim inputs, i
            Set inputs = document.getElementsByTagName("input")
            For i = 0 To inputs.length - 1
                If inputs(i).type = "checkbox" And inputs(i).id <> "" Then
                    If inputs(i).checked Then
                        shell.RegWrite REG_PATH & inputs(i).id, "True", "REG_SZ"
                    Else
                        shell.RegWrite REG_PATH & inputs(i).id, "False", "REG_SZ"
                    End If
                End If
            Next
        
            If Err.Number <> 0 Then
                ShowMessage "Something wrong during save", "msg-error"
                Err.Clear
            End If
        End Sub

        Sub DeleteAllRegistry()
            On Error Resume Next
            Dim arrKeys, i
            arrKeys = Array("DataFile", "LogFile", "WeaponListData", "ItemListData", "HeadListData", "IdolListData", "IdolWigListData", "ReinforcedListData", "SpesificNameWeapon", "SpesificNameItem", "SpesificNameHead", "RoomTitle", "RoomPassword", "chkCreateRoom", "chkLog", "chkUsePoint")
            For i = 0 To UBound(arrKeys)
                shell.RegDelete REG_PATH & arrKeys(i)
            Next
            If Err.Number <> 0 Then Err.Clear
        End Sub
                
        Sub SaveConfiguration()
            document.body.Focus
            If IsAllInputEmpty() Then
                DeleteAllRegistry
                WeaponListData = ""
                ItemListData = ""
                TempWeaponListData = ""
                TempItemListData = ""
                isEditingSpesificList = False
                RefreshSpesificList
                ShowMessage "", ""
                Exit Sub
            End If
            If ValidateFields(1, Nothing) = False Then Exit Sub
            If ValidateDataFile(document.getElementById("txtDataFile")) = False Then Exit Sub
            If ValidateLogFile(document.getElementById("txtLogFile")) = False Then Exit Sub
            SaveSettings
            ShowMessage "Configuration saved", ""
        End Sub
        
        Sub ShowMessage(msg, typeClass)
            Dim feedback
            Set feedback = document.getElementById("feedbackMsg")
            if msg = "" Then
                feedback.style.display = "none"
            Else
                feedback.style.display = "block"
                feedback.innerHTML = msg
                feedback.className = "msg " & typeClass
            End If
            window.CenterFeedback
        End Sub
    </script>
</head>

<body>
    <div class="container" id="mainContent" style="display: block;">
        <h3>Game Boost Auto Buy Shop Settings</h3>
        <div id="mainPanel" style="height: 197px; background: rgba(0, 30, 50, 0.5);">
            <div style="display: inline-block;">
                <div class="header" style="display: table;">Data File</div>
                <input title="Input Data File" type="text" id="txtDataFile" style="display: inline-block; width: 249px;" onkeyup="ValidateDataFile(this)" onkeypress="ValidateDataFile(this)" onblur="clearValidationClass(this)"/>
                <button title="Ctrl + F Then D" type="button" id="btnBrowseDataFile" onclick="document.getElementById('fileData').click()">Browse Data File</button>
                <input type="file" id="fileData" style="display:none" onchange="SetDataFile()"/>
            </div>
            <div style="display: inline-block;">
                <div class="header" style="display: table;">Log File</div>
                <input title="Input Log File" type="text" id="txtLogFile" style="display: inline-block; width: 249px;" onkeyup="ValidateLogFile(this)" onkeypress="ValidateLogFile(this)" onblur="clearValidationClass(this)"/>
                <button title="Ctrl + F Then L" type="button" id="btnBrowseLogFile" onclick="document.getElementById('fileLog').click()">Browse Log File</button>
                <input type="file" id="fileLog" style="display:none" onchange="SetLogFile()"/>
            </div>
            <div class="header" style="margin: 0;">Other</div>
            <div class="list-content">
                <input type="checkbox" id="chkCreateRoom">
                <label for="chkCreateRoom">Create Room</label>
                <input type="checkbox" id="chkLog">
                <label for="chkLog">Detailed Log</label>
                <input type="checkbox" id="chkUsePoint">
                <label for="chkUsePoint">Use Point Item</label>
            </div>
        </div>
        <div class="list-content" style="border-width: 5px;">
            <div style="margin-top: -5px;">
                <div style="display: inline-block;">
                    <div class="header" style="display: table;">Room Title</div>
                    <input type="text" title="Input Room Title (Enter to save)" id="txtRoomTitle" style="display: inline-block; width: 360px;" onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
                </div>
                <div style="display: inline-block;">
                    <div class="header" style="display: table;">Room Password</div>
                    <input type="text" title="Input Room Password (Enter to save)" id="txtRoomPassword" style="display: inline-block; width: 360px;" onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
                    <button title="Ctrl + W" type="button" onclick="ShowSpesificList()">Add List</button>
                </div>
            </div>
        </div>
        <div class="footer">
            <div style="height: 33px;"></div>
            <div style="float:left; margin-left: 10px;">
                <button title="Ctrl + S" onclick="SaveConfiguration()">Save</button>
                <button title="F1" onclick="StartExeScript()">Run Script</button>
            </div>
            <div style="float:right; margin-right: 10px;">
                <button title="Ctrl + R" class="btn-danger" onclick="ResetForm()">Reset All</button>
                <button title="Escape/Esc" class="btn-danger" onclick="self.close()">Discard</button>
            </div>
            <div style="width: 100%; margin: 0; margin-top: 45px; margin-bottom: -7px;">
                <a style="float: left;" class="header whatsapp" href="#" onclick="OpenLink('https://api.whatsapp.com/send?phone=6289528513371')">Whatsapp: 0895-2851-3371</a>
                <a class="header facebook" href="#" onclick="OpenLink('https://www.facebook.com/topupdisiniaja?rdid=l5sEgiU3Eb6Gkn1O&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F14eRyBmzCTC%2F#')">Facebook: Abdullah Khareem</a>
                <a style="float: right;" class="header instagram" href="#" onclick="OpenLink('https://www.instagram.com/topup_disini_aja')">Instagram: topup_disini_aja</a>
            </div>
        </div>
    </div>
    <div class="container" id="spesificListContent" style="display:none;">
        <h3>Spesific List</h3>
        <div id="spesificListPanel" style="height: 205px;"></div>
        <div class="list-content" style="border-width: 5px;">
            <div style="display: inline-block; margin: -5px 0 0 0;">
                <div class="header" style="display: table;">Input Weapon Name</div>
                <input type="text" title="Input Spesific Name (Enter/Ctrl + Enter/Alt + Enter to list weapon/item/head)" id="txtWeaponNamePopup" style="display: inline-block; width: 276px;"  onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
            </div>
            <div style="display: inline-block; margin: -5px 0 0 0;">
                <div class="header" style="display: table;">Input Head Name</div>
                <input type="text" title="Input Spesific Name (Enter/Ctrl + Enter/Alt + Enter to list weapon/item/head)" id="txtHeadNamePopup" style="display: inline-block; width: 276px;"  onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
            </div>
            <div style="display: inline-block; margin: -5px 0 0 0;">
                <div class="header" style="display: table;">Input Reinforced Name</div>
                <input type="text" title="Input Spesific Name (Enter/Ctrl + Enter/Alt + Enter to list weapon/item/head)" id="txtReinforcedNamePopup" style="display: inline-block; width: 276px;"  onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
            </div>
            <div style="display: inline-block; margin: -5px 0 -5px 0;">
                <div class="header" style="display: table;">Input Item Name</div>
                <input type="text" title="Input Spesific Name (Enter/Ctrl + Enter/Alt + Enter to list weapon/item/head)" id="txtItemNamePopup" style="display: inline-block; width: 276px;"  onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
            </div>
            <div style="display: inline-block; margin: -5px 0 -5px 0;">
                <div class="header" style="display: table;">Input Idol Name</div>
                <input type="text" title="Input Spesific Name (Enter/Ctrl + Enter/Alt + Enter to list weapon/item/head)" id="txtIdolNamePopup" style="display: inline-block; width: 276px;"  onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
            </div>
            <div style="display: inline-block; margin: -5px 0 -5px 0;">
                <div class="header" style="display: table;">Input Idol Wig Name</div>
                <input type="text" title="Input Spesific Name (Enter/Ctrl + Enter/Alt + Enter to list weapon/item/head)" id="txtIdolWigNamePopup" style="display: inline-block; width: 276px;"  onkeyup="ValidateFields(0, this)" onkeypress="ValidateFields(0, this)" onblur="clearValidationClass(this)"/>
            </div>
        </div>
        <div class="footer">
            <div style="height: 33px;"></div>
            <div style="float:left; margin-left: 10px;">
                <button title="Ctrl + S" onclick="SaveSpesificListChanges()">Save</button>
                <button title="F1" onclick="StartExeScript()">Run Script</button>
            </div>
            <div style="float:right; margin-right: 10px;">
                <button title="Ctrl + D" class="btn-danger" onclick="DeleteAllSpesifics()">Delete All</button>
                <button title="Escape/Esc" class="btn-danger" onclick="DiscardSpesificListChanges()">Discard</button>
            </div>
            <div style="width: 100%; margin: 0; margin-top: 45px; margin-bottom: -8px;">
                <a style="float: left;" class="header whatsapp" href="#" onclick="OpenLink('https://api.whatsapp.com/send?phone=6289528513371')">Whatsapp: 0895-2851-3371</a>
                <a class="header facebook" href="#" onclick="OpenLink('https://www.facebook.com/topupdisiniaja?rdid=l5sEgiU3Eb6Gkn1O&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F14eRyBmzCTC%2F#')">Facebook: Abdullah Khareem</a>
                <a style="float: right;" class="header instagram" href="#" onclick="OpenLink('https://www.instagram.com/topup_disini_aja')">Instagram: topup_disini_aja</a>
            </div>
        </div>
    </div>
    <div class="container" id="informationContent" style="display:none;">
        <h3>Information</h3>
        <div id="informationPanel" style="height: 398px; padding: 5px;">
            <div class="list-content">
